{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "jsx": "preserve",
    "isolatedModules": false,
    "noEmit": true,
    "esModuleInterop": true
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node",
      "jsx": "preserve"
    }
  },
  "include": ["scripts/**/*.ts", "prisma/**/*.ts", "src/**/*.ts"]
}
