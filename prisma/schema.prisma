generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  username     String?  @unique
  passwordHash String   @map("password_hash")
  role         String   @default("receptionist")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")

  userRoles           UserRole[]
  permissionOverrides UserPermissionOverride[]

  // ---- Tasks module ----
  ownedBoards      TaskBoard[]       @relation("BoardOwner")
  boardMemberships TaskBoardMember[]
  createdTasks     Task[]            @relation("TaskCreator")
  taskAssignments  TaskAssignee[]
  taskAttachments  TaskAttachment[]  @relation("TaskAttachmentUploader")
  taskComments     TaskComment[]
  taskActivities   TaskActivity[]

  // ---- Chat module ----
  createdConversations ChatConversation[]      @relation("ConversationCreator")
  chatParticipations   ChatParticipant[]
  chatMessages         ChatMessage[]
  chatReactions        ChatReaction[]
  chatAttachments      ChatMessageAttachment[] @relation("ChatAttachmentUploader")

  // ---- Notifications ----
  notifications Notification[]

  // ---- Reservation audit ----
  reservationStatusLogs ReservationStatusLog[]
  extensionsCreated     ReservationExtension[] @relation("ReservationExtensionCreator")
  extensionsReversed    ReservationExtension[] @relation("ReservationExtensionReverser")

  @@map("users")
}

model Unit {
  id              Int     @id @default(autoincrement())
  unitNumber      String  @unique @map("unit_number")
  unitType        String  @map("unit_type") // DEPRECATED: kept for backward-compat with /api/units?type=room|apartment; will be removed in Phase 3 after UI migration.
  unitTypeId      Int?    @map("unit_type_id")
  status          String  @default("available")
  floor           Int     @default(1)
  description     String?
  notes           String?
  bedSetup        String  @default("default") @map("bed_setup") // default | combined | separated
  bookingRoomCode String? @map("booking_room_code")

  unitTypeRef  UnitType?     @relation(fields: [unitTypeId], references: [id])
  reservations Reservation[]
  maintenance  Maintenance[]
  photos       UnitPhoto[]

  /// Room-to-room merging pair (1↔1). A `Unit` appears in either side A or
  /// side B of exactly ONE `UnitMerge` row. The helpers in
  /// `src/lib/units/merge.ts` always normalize storage so that unitAId <
  /// unitBId, eliminating the need for duplicate rows.
  mergeAsA UnitMerge? @relation("UnitMergeA")
  mergeAsB UnitMerge? @relation("UnitMergeB")

  @@index([unitTypeId])
  @@index([status])
  @@map("units")
}

/// Per-unit (room-level) photos — optional overrides on top of UnitTypePhoto.
/// Most properties will set photos at the UnitType level (one gallery per
/// room category) and only add UnitPhoto rows when a specific room differs
/// from the template (corner unit, upgraded finishes, balcony view, etc.).
model UnitPhoto {
  id        Int      @id @default(autoincrement())
  unitId    Int      @map("unit_id")
  /// Either a full URL ("https://...") or a stored path prefixed with
  /// "stored:YYYY/MM/abcdef.jpg" — served via /api/files/unit-photo/<id>.
  url       String
  captionAr String?  @map("caption_ar")
  captionEn String?  @map("caption_en")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, sortOrder])
  @@map("unit_photos")
}

// ============================================================================
// Unit Types (Room Types catalog — Booking.com-compatible)
// ============================================================================

model UnitType {
  id            Int     @id @default(autoincrement())
  code          String  @unique
  nameAr        String  @map("name_ar")
  nameEn        String  @map("name_en")
  category      String // apartment | hotel_room | suite | studio
  descriptionAr String? @map("description_ar")
  descriptionEn String? @map("description_en")

  maxAdults    Int @default(2) @map("max_adults")
  maxChildren  Int @default(0) @map("max_children")
  maxOccupancy Int @map("max_occupancy")

  sizeSqm        Float?  @map("size_sqm")
  hasKitchen     Boolean @default(false) @map("has_kitchen")
  hasBalcony     Boolean @default(false) @map("has_balcony")
  smokingAllowed Boolean @default(false) @map("smoking_allowed")
  view           String? // sea | city | garden | street | none

  bookingRoomId String? @unique @map("booking_room_id")
  channelSync   Boolean @default(false) @map("channel_sync")

  // ---- Direct-booking / public website (Phase 2) ----
  /// Default nightly rate displayed publicly when no active SeasonalPrice /
  /// UnitTypePrice row covers the date range. Nullable so legacy types that
  /// rely solely on seasonal pricing keep working unchanged.
  basePriceDaily   Float?  @map("base_price_daily")
  /// Controls whether this room type surfaces on `/book` — admins can hide
  /// a type from the public site without archiving it entirely.
  publiclyBookable Boolean @default(true) @map("publicly_bookable")

  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  rooms     UnitTypeRoom[]
  amenities UnitTypeAmenity[]
  photos    UnitTypePhoto[]
  units     Unit[]
  prices    UnitTypePrice[]

  @@index([category])
  @@index([isActive])
  @@map("unit_types")
}

model UnitTypeRoom {
  id         Int    @id @default(autoincrement())
  unitTypeId Int    @map("unit_type_id")
  nameAr     String @map("name_ar")
  nameEn     String @map("name_en")
  kind       String // bedroom | living_room | studio | bathroom
  position   Int    @default(0)

  unitType UnitType      @relation(fields: [unitTypeId], references: [id], onDelete: Cascade)
  beds     UnitTypeBed[]

  @@index([unitTypeId, position])
  @@map("unit_type_rooms")
}

model UnitTypeBed {
  id          Int     @id @default(autoincrement())
  roomId      Int     @map("room_id")
  bedType     String  @map("bed_type") // single | double | queen | king | sofa_bed | bunk_bed | crib | arabic_floor_seating
  count       Int     @default(1)
  /// When true, this bed represents a rollaway / extra bed (sleeps one
  /// additional guest). Enforced at the API level to AT MOST ONE bed per
  /// `UnitTypeRoom` carrying this flag.
  sleepsExtra Boolean @default(false) @map("sleeps_extra")
  notes       String?

  room UnitTypeRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("unit_type_beds")
}

/// Physical room-to-room merging via adjoining side door.
///
/// The hotel has pairs of neighbouring rooms with a door between them that
/// can be opened to convert the pair into a family apartment. This table
/// stores such pairs. Each Unit can participate in AT MOST one merge pair
/// (enforced by the two `@unique` constraints below). We always normalize
/// storage so unit_a_id < unit_b_id to avoid duplicate mirrored rows.
model UnitMerge {
  id        Int      @id @default(autoincrement())
  unitAId   Int      @unique @map("unit_a_id")
  unitBId   Int      @unique @map("unit_b_id")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  unitA Unit @relation("UnitMergeA", fields: [unitAId], references: [id], onDelete: Cascade)
  unitB Unit @relation("UnitMergeB", fields: [unitBId], references: [id], onDelete: Cascade)

  @@unique([unitAId, unitBId])
  @@map("unit_merges")
}

model Amenity {
  id       Int     @id @default(autoincrement())
  code     String  @unique
  nameAr   String  @map("name_ar")
  nameEn   String  @map("name_en")
  icon     String?
  category String  @default("general") // general | bathroom | kitchen | entertainment | outdoor

  unitTypes UnitTypeAmenity[]

  @@map("amenities")
}

model UnitTypeAmenity {
  unitTypeId Int @map("unit_type_id")
  amenityId  Int @map("amenity_id")

  unitType UnitType @relation(fields: [unitTypeId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([unitTypeId, amenityId])
  @@index([amenityId])
  @@map("unit_type_amenities")
}

model UnitTypePhoto {
  id         Int      @id @default(autoincrement())
  unitTypeId Int      @map("unit_type_id")
  url        String
  captionAr  String?  @map("caption_ar")
  captionEn  String?  @map("caption_en")
  isPrimary  Boolean  @default(false) @map("is_primary")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  unitType UnitType @relation(fields: [unitTypeId], references: [id], onDelete: Cascade)

  @@index([unitTypeId, sortOrder])
  @@map("unit_type_photos")
}

model Reservation {
  id                Int      @id @default(autoincrement())
  unitId            Int      @map("unit_id")
  guestName         String   @map("guest_name")
  guestIdNumber     String?  @map("guest_id_number")
  nationality       String?
  phone             String?
  numNights         Int      @map("num_nights")
  stayType          String   @default("daily") @map("stay_type")
  checkIn           DateTime @map("check_in") // scheduled check-in
  checkOut          DateTime @map("check_out") // scheduled check-out
  unitPrice         Float    @map("unit_price")
  totalAmount       Float    @map("total_amount")
  paidAmount        Float    @default(0) @map("paid_amount")
  remaining         Float    @default(0)
  paymentMethod     String?  @map("payment_method")
  status            String   @default("active")
  groupId           String?  @map("group_id")
  numGuests         Int      @default(1) @map("num_guests")
  notes             String?
  bedSetupRequested String?  @map("bed_setup_requested") // default | combined | separated (null = no preference)
  createdAt         DateTime @default(now()) @map("created_at")

  // ---- Direct-booking (Phase 2) ----
  /// Channel the reservation came from. Used for reporting and for flagging
  /// rows in the staff UI. Values: staff | direct_web | booking_com | whatsapp
  source           String    @default("staff")
  /// When non-null the row is a short-lived "hold" (status = pending_hold)
  /// created by `/api/book/hold`. Overlap checks exclude holds that have
  /// already expired. Cleared when the hold is confirmed or cancelled.
  holdExpiresAt    DateTime? @map("hold_expires_at")
  /// Short public-facing code shown to the guest once confirmed — e.g.
  /// "FKH-A7B3X". Guests use it to pull up their reservation from /account
  /// or from the confirmation page without authenticating.
  confirmationCode String?   @unique @map("confirmation_code")
  /// Optional link back to the GuestAccount that booked online. null for
  /// staff-entered reservations (the guest may not have an account).
  guestAccountId   Int?      @map("guest_account_id")

  // ---- Hotel-desk operational timestamps ----
  // Captured by front-desk actions (Check-In / Check-Out buttons). These are
  // distinct from `checkIn` / `checkOut`, which remain the *scheduled* window.
  actualCheckInAt  DateTime? @map("actual_check_in_at")
  actualCheckOutAt DateTime? @map("actual_check_out_at")
  checkedInById    Int?      @map("checked_in_by")
  checkedOutById   Int?      @map("checked_out_by")

  // ---- No-show / cancellation metadata ----
  noShow             Boolean   @default(false) @map("no_show")
  noShowAt           DateTime? @map("no_show_at")
  cancellationReason String?   @map("cancellation_reason")
  cancelledAt        DateTime? @map("cancelled_at")
  cancelledById      Int?      @map("cancelled_by")

  unit         Unit                   @relation(fields: [unitId], references: [id])
  guestAccount GuestAccount?          @relation(fields: [guestAccountId], references: [id])
  guests       Guest[]
  transactions Transaction[]
  statusLogs   ReservationStatusLog[]
  extensions   ReservationExtension[]

  @@index([status])
  @@index([actualCheckInAt])
  @@index([source, createdAt])
  @@index([guestAccountId])
  @@index([holdExpiresAt])
  @@map("reservations")
}

/// Append-only log of every reservation extension event. Each row keeps
/// enough "before" state to support a clean reversal (undo) even after
/// multiple extensions, and acts as the authoritative source when the
/// front-desk UI needs to show the history of a stay.
model ReservationExtension {
  id                  Int       @id @default(autoincrement())
  reservationId       Int       @map("reservation_id")
  additionalNights    Int       @map("additional_nights")
  stayType            String    @default("daily") @map("stay_type")
  addedAmount         Float     @map("added_amount")
  addedPaid           Float     @default(0) @map("added_paid")
  paymentMethod       String?   @map("payment_method")
  note                String?
  // Snapshot of the reservation BEFORE this extension was applied — used
  // to restore state on reversal.
  previousCheckOut    DateTime  @map("previous_check_out")
  newCheckOut         DateTime  @map("new_check_out")
  previousNumNights   Int       @map("previous_num_nights")
  newNumNights        Int       @map("new_num_nights")
  previousTotalAmount Float     @map("previous_total_amount")
  newTotalAmount      Float     @map("new_total_amount")
  previousPaidAmount  Float     @map("previous_paid_amount")
  newPaidAmount       Float     @map("new_paid_amount")
  previousStatus      String    @map("previous_status")
  createdById         Int?      @map("created_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  reversedAt          DateTime? @map("reversed_at")
  reversedById        Int?      @map("reversed_by")
  reversalReason      String?   @map("reversal_reason")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("ReservationExtensionCreator", fields: [createdById], references: [id])
  reversedBy  User?       @relation("ReservationExtensionReverser", fields: [reversedById], references: [id])

  @@index([reservationId, createdAt])
  @@index([reversedAt])
  @@map("reservation_extensions")
}

/// Append-only audit trail of every reservation state transition.
/// Consumed by the reservation detail UI and by audit/export reports.
/// Never mutated after insert.
model ReservationStatusLog {
  id            Int      @id @default(autoincrement())
  reservationId Int      @map("reservation_id")
  fromStatus    String   @map("from_status")
  toStatus      String   @map("to_status")
  /// One of:
  ///   check_in | check_out | cancel | no_show | reopen | extend
  ///   auto_activate | auto_complete | edit  (edit = financial repost)
  action        String
  reason        String?
  actorUserId   Int?     @map("actor_user_id")
  at            DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  actor       User?       @relation(fields: [actorUserId], references: [id])

  @@index([reservationId, at])
  @@index([action, at])
  @@map("reservation_status_logs")
}

model Guest {
  id            Int     @id @default(autoincrement())
  reservationId Int     @map("reservation_id")
  guestOrder    Int     @map("guest_order")
  fullName      String  @map("full_name")
  idNumber      String  @map("id_number")
  nationality   String  @default("")
  idDocImage    String? @map("id_doc_image")
  notes         String?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("guests")
}

// ============================================================================
// Guest accounts (direct booking — Phase 1)
// ============================================================================
//
// Intentionally separate from `User` (staff) so the admin RBAC system stays
// clean: guests have no role / no permissions — only ownership of their own
// reservations. NextAuth has a dedicated "guest-credentials" provider that
// reads this table and a JWT `audience: "guest"` claim to distinguish the
// two audiences in middleware.

model GuestAccount {
  id              Int       @id @default(autoincrement())
  /// E.164 digits without the leading "+" (e.g. "962781099910"). Primary
  /// identifier for guests — we authenticate by phone + password and verify
  /// ownership via a WhatsApp OTP.
  phone           String    @unique
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  email           String?   @unique
  emailVerifiedAt DateTime? @map("email_verified_at")
  passwordHash    String    @map("password_hash")
  fullName        String    @map("full_name")
  nationality     String?
  idNumber        String?   @map("id_number")
  idDocImage      String?   @map("id_doc_image")
  preferredLang   String    @default("ar") @map("preferred_lang") // ar | en
  avatarUrl       String?   @map("avatar_url")
  disabledAt      DateTime? @map("disabled_at")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  reservations Reservation[]

  @@index([createdAt])
  @@map("guest_accounts")
}

/// Short-lived one-time passwords used for guest phone-verification flows:
/// signup (own the phone), passwordless login, password reset, or
/// change-phone. Codes are stored bcrypt-hashed; the plain code is sent
/// only via WhatsApp.
model GuestOtp {
  id         Int       @id @default(autoincrement())
  phone      String
  /// Scrypt/bcrypt hash of the 6-digit code. Never store plain codes.
  codeHash   String    @map("code_hash")
  /// signup | login | reset | change_phone
  purpose    String
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  attempts   Int       @default(0)
  ip         String?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([phone, purpose, expiresAt])
  @@index([expiresAt])
  @@map("guest_otps")
}

/// DEPRECATED: legacy per-category pricing. Kept for backward-compat while
/// migrating to UnitTypePrice (Phase 5). Will be removed after full migration.
model SeasonalPrice {
  id          Int      @id @default(autoincrement())
  seasonName  String   @map("season_name")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  roomDaily   Float    @map("room_daily")
  roomWeekly  Float    @map("room_weekly")
  roomMonthly Float    @map("room_monthly")
  aptDaily    Float    @map("apt_daily")
  aptWeekly   Float    @map("apt_weekly")
  aptMonthly  Float    @map("apt_monthly")

  seasonId Int?    @map("season_id")
  season   Season? @relation(fields: [seasonId], references: [id])

  @@map("seasonal_prices")
}

/// A date range used to group per-unit-type prices (high/low/Ramadan, etc.).
model Season {
  id        Int      @id @default(autoincrement())
  nameAr    String   @map("name_ar")
  nameEn    String?  @map("name_en")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  prices         UnitTypePrice[]
  seasonalPrices SeasonalPrice[]

  @@index([startDate, endDate])
  @@map("seasons")
}

/// Per-unit-type price for a given season. One row per (unitType × season).
model UnitTypePrice {
  id         Int   @id @default(autoincrement())
  unitTypeId Int   @map("unit_type_id")
  seasonId   Int   @map("season_id")
  daily      Float @default(0)
  weekly     Float @default(0)
  monthly    Float @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  unitType UnitType @relation(fields: [unitTypeId], references: [id], onDelete: Cascade)
  season   Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([unitTypeId, seasonId])
  @@index([seasonId])
  @@map("unit_type_prices")
}

model Maintenance {
  id             Int       @id @default(autoincrement())
  unitId         Int       @map("unit_id")
  description    String
  contractor     String?
  cost           Float     @default(0)
  status         String    @default("pending")
  requestDate    DateTime  @default(now()) @map("request_date")
  completionDate DateTime? @map("completion_date")
  notes          String?

  unit Unit  @relation(fields: [unitId], references: [id])
  task Task?

  @@map("maintenance")
}

model Transaction {
  id            Int      @id @default(autoincrement())
  date          DateTime
  description   String
  reservationId Int?     @map("reservation_id")
  amount        Float
  type          String
  account       String
  bankRef       String?  @map("bank_ref")
  createdAt     DateTime @default(now()) @map("created_at")

  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@map("transactions")
}

// ============================================================================
// Double-Entry Accounting Models
// ============================================================================

model Account {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  type          String // asset | liability | equity | revenue | expense
  subtype       String? // cash | bank | ar | ap | capital | drawing | ...
  normalBalance String   @map("normal_balance") // debit | credit
  parentId      Int?     @map("parent_id")
  isSystem      Boolean  @default(false) @map("is_system")
  isActive      Boolean  @default(true) @map("is_active")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  parent    Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children  Account[]     @relation("AccountTree")
  lines     JournalLine[]
  partiesAR Party[]       @relation("ARAccount")
  partiesAP Party[]       @relation("APAccount")
  partiesEq Party[]       @relation("EquityAccount")
  partiesDr Party[]       @relation("DrawAccount")

  @@index([type])
  @@index([parentId])
  @@map("accounts")
}

model Party {
  id              Int       @id @default(autoincrement())
  code            String?   @unique
  name            String
  type            String // guest | partner | supplier | employee | lender | other
  phone           String?
  email           String?
  nationalId      String?   @map("national_id")
  notes           String?
  isActive        Boolean   @default(true) @map("is_active")
  openingBalance  Float     @default(0) @map("opening_balance")
  openingDate     DateTime? @map("opening_date")
  arAccountId     Int?      @map("ar_account_id")
  apAccountId     Int?      @map("ap_account_id")
  equityAccountId Int?      @map("equity_account_id")
  drawAccountId   Int?      @map("draw_account_id")

  // ---- Employee-specific fields (used when type = 'employee') ----
  baseSalary      Float?    @map("base_salary")
  commissionRate  Float?    @map("commission_rate") // e.g. 0.05 = 5% of rental revenue
  salaryPayDay    Int?      @map("salary_pay_day") // day of month (1-28) when salary is due
  hireDate        DateTime? @map("hire_date")
  terminationDate DateTime? @map("termination_date")
  jobTitle        String?   @map("job_title")

  createdAt DateTime @default(now()) @map("created_at")

  arAccount     Account?      @relation("ARAccount", fields: [arAccountId], references: [id])
  apAccount     Account?      @relation("APAccount", fields: [apAccountId], references: [id])
  equityAccount Account?      @relation("EquityAccount", fields: [equityAccountId], references: [id])
  drawAccount   Account?      @relation("DrawAccount", fields: [drawAccountId], references: [id])
  lines         JournalLine[]

  @@index([type])
  @@index([isActive])
  @@map("parties")
}

model JournalEntry {
  id           Int       @id @default(autoincrement())
  entryNumber  String    @unique @map("entry_number")
  date         DateTime
  description  String
  reference    String?
  source       String // manual | reservation | payment | expense | salary | opening | reversal
  sourceRefId  Int?      @map("source_ref_id")
  status       String    @default("posted") // draft | posted | void
  totalDebit   Float     @map("total_debit")
  totalCredit  Float     @map("total_credit")
  createdById  Int?      @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  voidedAt     DateTime? @map("voided_at")
  voidedById   Int?      @map("voided_by")
  voidReason   String?   @map("void_reason")
  reversalOfId Int?      @map("reversal_of_id")

  lines      JournalLine[]
  reversalOf JournalEntry?  @relation("Reversal", fields: [reversalOfId], references: [id])
  reversedBy JournalEntry[] @relation("Reversal")

  @@index([date])
  @@index([source, sourceRefId])
  @@index([status])
  @@map("journal_entries")
}

model JournalLine {
  id          Int     @id @default(autoincrement())
  entryId     Int     @map("entry_id")
  accountId   Int     @map("account_id")
  partyId     Int?    @map("party_id")
  debit       Float   @default(0)
  credit      Float   @default(0)
  description String?
  lineOrder   Int     @map("line_order")

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])
  party   Party?       @relation(fields: [partyId], references: [id])

  @@index([entryId])
  @@index([accountId])
  @@index([partyId])
  @@map("journal_lines")
}

model FiscalPeriod {
  id       Int       @id @default(autoincrement())
  year     Int
  month    Int
  status   String    @default("open") // open | closed
  closedAt DateTime? @map("closed_at")
  closedBy Int?      @map("closed_by")

  @@unique([year, month])
  @@map("fiscal_periods")
}

model AccountingCounter {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value Int    @default(0)

  @@map("accounting_counters")
}

// ============================================================================
// Permissions / RBAC
// ============================================================================

model Resource {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  label       String
  category    String   @default("general")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  permissions Permission[]

  @@index([category])
  @@map("resources")
}

model Permission {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  resourceId Int      @map("resource_id")
  action     String
  label      String
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  resource        Resource                 @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userOverrides   UserPermissionOverride[]

  @@unique([resourceId, action])
  @@index([action])
  @@map("permissions")
}

model Role {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model UserPermissionOverride {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  permissionId Int      @map("permission_id")
  effect       String // allow | deny
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
  @@map("user_permission_overrides")
}

// ============================================================================
// Tasks Module (Kanban)
// ============================================================================

model TaskBoard {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  color       String? // hex color for UI accent
  ownerId     Int       @map("owner_id")
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  owner   User              @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members TaskBoardMember[]
  columns TaskColumn[]
  tasks   Task[]
  labels  TaskLabel[]

  @@index([ownerId])
  @@index([archivedAt])
  @@map("task_boards")
}

model TaskBoardMember {
  id        Int      @id @default(autoincrement())
  boardId   Int      @map("board_id")
  userId    Int      @map("user_id")
  role      String   @default("editor") // owner | editor | viewer
  createdAt DateTime @default(now()) @map("created_at")

  board TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
  @@map("task_board_members")
}

model TaskColumn {
  id        Int      @id @default(autoincrement())
  boardId   Int      @map("board_id")
  name      String
  position  Int
  wipLimit  Int?     @map("wip_limit")
  createdAt DateTime @default(now()) @map("created_at")

  board TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId, position])
  @@map("task_columns")
}

model Task {
  id            Int       @id @default(autoincrement())
  boardId       Int       @map("board_id")
  columnId      Int       @map("column_id")
  title         String
  description   String?
  priority      String    @default("med") // low | med | high | urgent
  dueAt         DateTime? @map("due_at")
  startAt       DateTime? @map("start_at")
  position      Int
  createdById   Int       @map("created_by")
  archivedAt    DateTime? @map("archived_at")
  completedAt   DateTime? @map("completed_at")
  maintenanceId Int?      @unique @map("maintenance_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  board         TaskBoard           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column        TaskColumn          @relation(fields: [columnId], references: [id])
  createdBy     User                @relation("TaskCreator", fields: [createdById], references: [id])
  maintenance   Maintenance?        @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)
  assignees     TaskAssignee[]
  labels        TaskLabelOnTask[]
  checklist     TaskChecklistItem[]
  attachments   TaskAttachment[]
  comments      TaskComment[]
  activities    TaskActivity[]
  conversations ChatConversation[]  @relation("TaskConversations")

  @@index([boardId, columnId, position])
  @@index([dueAt])
  @@index([completedAt])
  @@map("tasks")
}

model TaskAssignee {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model TaskLabel {
  id      Int    @id @default(autoincrement())
  boardId Int    @map("board_id")
  name    String
  color   String @default("#6b7280")

  board TaskBoard         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks TaskLabelOnTask[]

  @@index([boardId])
  @@map("task_labels")
}

model TaskLabelOnTask {
  taskId  Int @map("task_id")
  labelId Int @map("label_id")

  task  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
  @@map("task_label_on_task")
}

model TaskChecklistItem {
  id       Int     @id @default(autoincrement())
  taskId   Int     @map("task_id")
  text     String
  done     Boolean @default(false)
  position Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, position])
  @@map("task_checklist_items")
}

model TaskAttachment {
  id           Int      @id @default(autoincrement())
  taskId       Int      @map("task_id")
  fileName     String   @map("file_name")
  mimeType     String   @map("mime_type")
  size         Int
  storagePath  String   @map("storage_path")
  uploadedById Int      @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("TaskAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([taskId])
  @@map("task_attachments")
}

model TaskComment {
  id        Int       @id @default(autoincrement())
  taskId    Int       @map("task_id")
  authorId  Int       @map("author_id")
  body      String
  createdAt DateTime  @default(now()) @map("created_at")
  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_comments")
}

model TaskActivity {
  id          Int      @id @default(autoincrement())
  taskId      Int      @map("task_id")
  actorId     Int      @map("actor_id")
  type        String // created | moved | assigned | unassigned | updated | completed | reopened | label_added | label_removed | attachment | commented
  payloadJson Json?    @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User @relation(fields: [actorId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_activities")
}

// ============================================================================
// Chat Module
// ============================================================================

model ChatConversation {
  id            Int       @id @default(autoincrement())
  type          String // dm | group | task
  title         String?
  taskId        Int?      @map("task_id")
  createdById   Int       @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastMessageAt DateTime? @map("last_message_at")

  task         Task?             @relation("TaskConversations", fields: [taskId], references: [id], onDelete: SetNull)
  createdBy    User              @relation("ConversationCreator", fields: [createdById], references: [id])
  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([taskId])
  @@index([lastMessageAt])
  @@map("chat_conversations")
}

model ChatParticipant {
  id             Int       @id @default(autoincrement())
  conversationId Int       @map("conversation_id")
  userId         Int       @map("user_id")
  role           String    @default("member") // admin | member
  lastReadAt     DateTime? @map("last_read_at")
  mutedUntil     DateTime? @map("muted_until")
  joinedAt       DateTime  @default(now()) @map("joined_at")
  leftAt         DateTime? @map("left_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model ChatMessage {
  id             Int       @id @default(autoincrement())
  conversationId Int       @map("conversation_id")
  senderId       Int       @map("sender_id")
  body           String
  replyToId      Int?      @map("reply_to_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  editedAt       DateTime? @map("edited_at")
  deletedAt      DateTime? @map("deleted_at")

  conversation ChatConversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                    @relation(fields: [senderId], references: [id])
  replyTo      ChatMessage?            @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      ChatMessage[]           @relation("MessageReplies")
  attachments  ChatMessageAttachment[]
  reactions    ChatReaction[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

model ChatMessageAttachment {
  id           Int      @id @default(autoincrement())
  messageId    Int      @map("message_id")
  fileName     String   @map("file_name")
  mimeType     String   @map("mime_type")
  size         Int
  storagePath  String   @map("storage_path")
  uploadedById Int      @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedBy User        @relation("ChatAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([messageId])
  @@map("chat_message_attachments")
}

model ChatReaction {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  userId    Int      @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("chat_reactions")
}

// ============================================================================
// Notifications
// ============================================================================

model Notification {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  type        String // task.assigned | task.due | task.commented | chat.message | chat.mention | ...
  title       String
  body        String?
  linkUrl     String?   @map("link_url")
  payloadJson Json?     @map("payload_json")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================================
// Booking.com integration (Phase 6)
// ============================================================================
//
// We don't use a third-party Channel Manager. Instead, a separate Node process
// (see bot/) drives Booking.com Extranet via Playwright. These tables are the
// contract between the web app (reads/writes jobs) and the bot (consumes them).
// Credentials are stored encrypted (AES-GCM) — never logged, never exposed.

/// Encrypted login credentials for Booking.com Extranet. One row per account.
model BookingCredential {
  id             Int       @id @default(autoincrement())
  label          String // e.g. "Main property"
  email          String
  passwordEnc    String    @map("password_enc") // base64(iv|tag|ciphertext)
  twoFaSecretEnc String?   @map("two_fa_secret_enc") // optional TOTP secret (encrypted)
  propertyId     String?   @map("property_id") // Booking property id (digits)
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginOk    Boolean?  @map("last_login_ok")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("booking_credentials")
}

/// Maps a local Unit (or UnitType) to its Booking.com room type/id.
/// We support two granularities: unitId (specific room) and unitTypeId (group).
model BookingPropertyMap {
  id               Int       @id @default(autoincrement())
  unitId           Int?      @unique @map("unit_id")
  unitTypeId       Int?      @unique @map("unit_type_id")
  extranetRoomId   String    @map("extranet_room_id")
  extranetRoomName String?   @map("extranet_room_name")
  extranetRoomCode String?   @map("extranet_room_code")
  lastSyncedAt     DateTime? @map("last_synced_at")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([unitId])
  @@index([unitTypeId])
  @@map("booking_property_map")
}

/// A unit of work for the bot. The web API enqueues jobs; the bot polls & runs.
model BookingSyncJob {
  id          Int       @id @default(autoincrement())
  type        String // login_check | push_prices | push_availability | pull_reservations
  status      String    @default("pending") // pending | running | done | failed | cancelled
  scheduledAt DateTime  @default(now()) @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  attempts    Int       @default(0)
  payloadJson Json?     @map("payload_json") // e.g. { seasonId, unitTypeIds, fromDate, toDate }
  resultJson  Json?     @map("result_json") // summary counts, timing
  error       String?
  createdBy   Int?      @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  logs BookingSyncLog[]

  @@index([status, scheduledAt])
  @@index([type, createdAt])
  @@map("booking_sync_jobs")
}

/// Append-only log stream for a job. Bot writes, UI reads.
model BookingSyncLog {
  id       Int      @id @default(autoincrement())
  jobId    Int      @map("job_id")
  ts       DateTime @default(now())
  level    String   @default("info") // info | warn | error
  message  String
  metaJson Json?    @map("meta_json")

  job BookingSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, ts])
  @@map("booking_sync_logs")
}

/// Inbox for reservations pulled from Booking before they are imported into
/// our own Reservation table (giving a human the chance to confirm mapping).
model BookingInboxReservation {
  id                 Int       @id @default(autoincrement())
  externalId         String    @unique @map("external_id") // Booking reservation number
  guestName          String    @map("guest_name")
  guestEmail         String?   @map("guest_email")
  guestPhone         String?   @map("guest_phone")
  checkIn            DateTime  @map("check_in")
  checkOut           DateTime  @map("check_out")
  extranetRoomId     String?   @map("extranet_room_id")
  mappedUnitId       Int?      @map("mapped_unit_id")
  numGuests          Int       @default(1) @map("num_guests")
  totalAmount        Float     @default(0) @map("total_amount")
  currency           String    @default("JOD")
  status             String    @default("new") // new | imported | ignored | conflict
  rawJson            Json?     @map("raw_json")
  localReservationId Int?      @map("local_reservation_id")
  importedAt         DateTime? @map("imported_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([checkIn, checkOut])
  @@map("booking_inbox_reservations")
}

// ============================================================================
// WhatsApp Business Cloud API integration
// ============================================================================

/// Singleton row holding the active WhatsApp Business Cloud API credentials.
/// We keep exactly one row (enforced in code) — `id = 1` — and store the
/// access token encrypted with the shared AES-256-GCM helper so it is never
/// exposed in logs/backups in plaintext.
model WhatsAppConfig {
  id                 Int       @id @default(1)
  appId              String?   @map("app_id")
  /// App Secret is needed to verify webhook signatures (X-Hub-Signature-256).
  appSecretEnc       String?   @map("app_secret_enc")
  wabaId             String?   @map("waba_id")
  phoneNumberId      String?   @map("phone_number_id")
  displayPhoneNumber String?   @map("display_phone_number")
  /// System-User permanent token. Never returned to the client unmasked.
  accessTokenEnc     String?   @map("access_token_enc")
  webhookVerifyToken String?   @map("webhook_verify_token")
  apiVersion         String    @default("v21.0") @map("api_version")
  isActive           Boolean   @default(true) @map("is_active")
  lastVerifiedAt     DateTime? @map("last_verified_at")
  lastVerifyOk       Boolean?  @map("last_verify_ok")
  lastError          String?   @map("last_error")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("whatsapp_config")
}

/// A WhatsApp message — inbound or outbound — logged for the inbox UI and
/// for audit/compliance. Threaded by the contact E.164 phone number so we
/// can also join against Reservation.phone / Guest without a formal FK.
model WhatsAppMessage {
  id              Int       @id @default(autoincrement())
  /// "inbound" (from customer) | "outbound" (from hotel)
  direction       String
  /// Meta message ID (wamid.xxxx) — unique per message, used for dedupe.
  wamid           String?   @unique
  /// E.164 contact phone (no "+"). For outbound = to, for inbound = from.
  contactPhone    String    @map("contact_phone")
  /// Display name of the WhatsApp profile (inbound only).
  contactName     String?   @map("contact_name")
  /// "text" | "image" | "document" | "template" | "audio" | "video" | "sticker" | "location" | "interactive" | "reaction" | "unknown"
  type            String    @default("text")
  /// Plain text body (for text messages OR the caption of media messages).
  body            String?
  /// When type="template", the template name used for the outbound send.
  templateName    String?   @map("template_name")
  /// Raw payload (Meta webhook message or send-response) for forensics.
  rawJson         Json?     @map("raw_json")
  /// Lifecycle for outbound: "queued" | "sent" | "delivered" | "read" | "failed".
  /// For inbound, usually "received".
  status          String    @default("queued")
  errorCode       String?   @map("error_code")
  errorMessage    String?   @map("error_message")
  /// Meta pricing category — passed through from the statuses webhook.
  pricingCategory String?   @map("pricing_category")
  /// When Meta marked the message sent / delivered / read.
  sentAt          DateTime? @map("sent_at")
  deliveredAt     DateTime? @map("delivered_at")
  readAt          DateTime? @map("read_at")
  /// Optional soft-link to a reservation (resolved on send / on inbound by phone match).
  reservationId   Int?      @map("reservation_id")
  /// Who triggered the send (for outbound). Null for webhook-originated rows.
  sentByUserId    Int?      @map("sent_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([contactPhone, createdAt])
  @@index([direction, status])
  @@index([reservationId])
  @@map("whatsapp_messages")
}

/// Cached snapshot of the message templates registered on the WABA. The
/// source of truth is Meta — we refresh via `GET /v{ver}/{WABA_ID}/message_templates`.
/// Only APPROVED templates are usable for outbound sends outside the 24h window.
model WhatsAppTemplate {
  id              Int      @id @default(autoincrement())
  /// Meta's template name (slug — lowercase snake_case).
  name            String
  language        String   @default("ar")
  category        String   @default("UTILITY") // AUTHENTICATION | MARKETING | UTILITY
  /// APPROVED | PENDING | REJECTED | PAUSED | DISABLED
  status          String   @default("PENDING")
  components      Json?
  metaId          String?  @unique @map("meta_id")
  rejectionReason String?  @map("rejection_reason")
  lastSyncedAt    DateTime @default(now()) @map("last_synced_at")

  @@unique([name, language])
  @@index([status])
  @@map("whatsapp_templates")
}
