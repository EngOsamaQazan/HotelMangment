generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  username      String?  @unique
  passwordHash  String   @map("password_hash")
  role          String   @default("receptionist")
  avatarUrl     String?  @map("avatar_url")
  /// Personal WhatsApp number (E.164 digits, no leading "+") used to deliver
  /// staff notifications when the "whatsapp" channel is enabled in their
  /// notification preferences. Optional — empty value means WhatsApp delivery
  /// is silently skipped for that user.
  whatsappPhone String?  @map("whatsapp_phone")
  createdAt     DateTime @default(now()) @map("created_at")

  userRoles           UserRole[]
  permissionOverrides UserPermissionOverride[]

  // ---- Tasks module ----
  ownedBoards      TaskBoard[]       @relation("BoardOwner")
  boardMemberships TaskBoardMember[]
  createdTasks     Task[]            @relation("TaskCreator")
  taskAssignments  TaskAssignee[]
  taskAttachments  TaskAttachment[]  @relation("TaskAttachmentUploader")
  taskComments     TaskComment[]
  taskActivities   TaskActivity[]

  // ---- Chat module ----
  createdConversations ChatConversation[]      @relation("ConversationCreator")
  chatParticipations   ChatParticipant[]
  chatMessages         ChatMessage[]
  chatReactions        ChatReaction[]
  chatAttachments      ChatMessageAttachment[] @relation("ChatAttachmentUploader")

  // ---- Notifications ----
  notifications           Notification[]
  notificationPreferences NotificationPreference[]

  // ---- Reservation audit ----
  reservationStatusLogs ReservationStatusLog[]
  extensionsCreated     ReservationExtension[] @relation("ReservationExtensionCreator")
  extensionsReversed    ReservationExtension[] @relation("ReservationExtensionReverser")

  // ---- WhatsApp module ----
  whatsappContactsCreated         WhatsAppContact[]           @relation("WhatsAppContactCreator")
  whatsappContactsUpdated         WhatsAppContact[]           @relation("WhatsAppContactUpdater")
  whatsappAssignedConversations   WhatsAppConversation[]      @relation("WhatsAppConversationAssignee")
  whatsappAssignedByConversations WhatsAppConversation[]      @relation("WhatsAppConversationAssigner")
  whatsappConversationNotes       WhatsAppConversationNote[]
  whatsappConversationEvents      WhatsAppConversationEvent[]
  whatsappPushSubscriptions       WhatsAppPushSubscription[]
  whatsappNotificationPref        WhatsAppNotificationPref?

  // ---- AI Concierge bot (Phase 0+) ----
  botAllowlistEntries BotAllowlist[]   @relation("BotAllowlistAdder")
  botShadowDecisions  BotShadowDraft[] @relation("BotShadowDraftDecider")

  @@map("users")
}

model Unit {
  id              Int     @id @default(autoincrement())
  unitNumber      String  @unique @map("unit_number")
  /// Foreign key to the canonical `UnitType` row. The legacy denormalised
  /// `unit_type` String column ("room" | "apartment") was dropped in
  /// Phase 4 of the unit-types redesign — derive the coarse classification
  /// from `unitTypeRef.category` via `legacyTypeFromUnitTypeRef()` instead.
  unitTypeId      Int?    @map("unit_type_id")
  status          String  @default("available")
  floor           Int     @default(1)
  description     String?
  notes           String?
  bedSetup        String  @default("default") @map("bed_setup") // default | combined | separated
  bookingRoomCode String? @map("booking_room_code")

  unitTypeRef  UnitType?     @relation(fields: [unitTypeId], references: [id])
  reservations Reservation[]
  maintenance  Maintenance[]
  photos       UnitPhoto[]

  /// Room-to-room merging pair (1↔1). A `Unit` appears in either side A or
  /// side B of exactly ONE `UnitMerge` row. The helpers in
  /// `src/lib/units/merge.ts` always normalize storage so that unitAId <
  /// unitBId, eliminating the need for duplicate rows.
  mergeAsA UnitMerge? @relation("UnitMergeA")
  mergeAsB UnitMerge? @relation("UnitMergeB")

  @@index([unitTypeId])
  @@index([status])
  @@map("units")
}

/// Per-unit (room-level) photos — optional overrides on top of UnitTypePhoto.
/// Most properties will set photos at the UnitType level (one gallery per
/// room category) and only add UnitPhoto rows when a specific room differs
/// from the template (corner unit, upgraded finishes, balcony view, etc.).
model UnitPhoto {
  id        Int      @id @default(autoincrement())
  unitId    Int      @map("unit_id")
  /// Either a full URL ("https://...") or a stored path prefixed with
  /// "stored:YYYY/MM/abcdef.jpg" — served via /api/files/unit-photo/<id>.
  url       String
  captionAr String?  @map("caption_ar")
  captionEn String?  @map("caption_en")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, sortOrder])
  @@map("unit_photos")
}

// ============================================================================
// Unit Types (Room Types catalog — Booking.com-compatible)
// ============================================================================

model UnitType {
  id            Int     @id @default(autoincrement())
  code          String  @unique
  nameAr        String  @map("name_ar")
  nameEn        String  @map("name_en")
  category      String // apartment | hotel_room | suite | studio
  descriptionAr String? @map("description_ar")
  descriptionEn String? @map("description_en")

  maxAdults    Int @default(2) @map("max_adults")
  maxChildren  Int @default(0) @map("max_children")
  maxOccupancy Int @map("max_occupancy")

  sizeSqm        Float?  @map("size_sqm")
  hasKitchen     Boolean @default(false) @map("has_kitchen")
  hasBalcony     Boolean @default(false) @map("has_balcony")
  smokingAllowed Boolean @default(false) @map("smoking_allowed")
  view           String? // sea | city | garden | street | none

  bookingRoomId String? @unique @map("booking_room_id")
  channelSync   Boolean @default(false) @map("channel_sync")

  // ---- Direct-booking / public website (Phase 2) ----
  /// Default nightly rate displayed publicly when no active SeasonalPrice /
  /// UnitTypePrice row covers the date range. Nullable so legacy types that
  /// rely solely on seasonal pricing keep working unchanged.
  basePriceDaily   Float?  @map("base_price_daily")
  /// Controls whether this room type surfaces on `/book` — admins can hide
  /// a type from the public site without archiving it entirely.
  publiclyBookable Boolean @default(true) @map("publicly_bookable")

  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  rooms     UnitTypeRoom[]
  amenities UnitTypeAmenity[]
  photos    UnitTypePhoto[]
  units     Unit[]
  prices    UnitTypePrice[]

  @@index([category])
  @@index([isActive])
  @@map("unit_types")
}

model UnitTypeRoom {
  id         Int    @id @default(autoincrement())
  unitTypeId Int    @map("unit_type_id")
  nameAr     String @map("name_ar")
  nameEn     String @map("name_en")
  kind       String // bedroom | living_room | studio | bathroom
  position   Int    @default(0)

  unitType UnitType      @relation(fields: [unitTypeId], references: [id], onDelete: Cascade)
  beds     UnitTypeBed[]

  @@index([unitTypeId, position])
  @@map("unit_type_rooms")
}

model UnitTypeBed {
  id          Int     @id @default(autoincrement())
  roomId      Int     @map("room_id")
  bedType     String  @map("bed_type") // single | double | queen | king | sofa_bed | bunk_bed | crib | arabic_floor_seating
  count       Int     @default(1)
  /// When true, this bed represents a rollaway / extra bed (sleeps one
  /// additional guest). Enforced at the API level to AT MOST ONE bed per
  /// `UnitTypeRoom` carrying this flag.
  sleepsExtra Boolean @default(false) @map("sleeps_extra")
  notes       String?

  room UnitTypeRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("unit_type_beds")
}

/// Physical room-to-room merging via adjoining side door.
///
/// The hotel has pairs of neighbouring rooms with a door between them that
/// can be opened to convert the pair into a family apartment. This table
/// stores such pairs. Each Unit can participate in AT MOST one merge pair
/// (enforced by the two `@unique` constraints below). We always normalize
/// storage so unit_a_id < unit_b_id to avoid duplicate mirrored rows.
model UnitMerge {
  id        Int      @id @default(autoincrement())
  unitAId   Int      @unique @map("unit_a_id")
  unitBId   Int      @unique @map("unit_b_id")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  unitA Unit @relation("UnitMergeA", fields: [unitAId], references: [id], onDelete: Cascade)
  unitB Unit @relation("UnitMergeB", fields: [unitBId], references: [id], onDelete: Cascade)

  @@unique([unitAId, unitBId])
  @@map("unit_merges")
}

model Amenity {
  id       Int     @id @default(autoincrement())
  code     String  @unique
  nameAr   String  @map("name_ar")
  nameEn   String  @map("name_en")
  icon     String?
  category String  @default("general") // general | bathroom | kitchen | entertainment | outdoor

  unitTypes UnitTypeAmenity[]

  @@map("amenities")
}

model UnitTypeAmenity {
  unitTypeId Int @map("unit_type_id")
  amenityId  Int @map("amenity_id")

  unitType UnitType @relation(fields: [unitTypeId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([unitTypeId, amenityId])
  @@index([amenityId])
  @@map("unit_type_amenities")
}

model UnitTypePhoto {
  id         Int      @id @default(autoincrement())
  unitTypeId Int      @map("unit_type_id")
  url        String
  captionAr  String?  @map("caption_ar")
  captionEn  String?  @map("caption_en")
  isPrimary  Boolean  @default(false) @map("is_primary")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  unitType UnitType @relation(fields: [unitTypeId], references: [id], onDelete: Cascade)

  @@index([unitTypeId, sortOrder])
  @@map("unit_type_photos")
}

model Reservation {
  id                Int      @id @default(autoincrement())
  unitId            Int      @map("unit_id")
  guestName         String   @map("guest_name")
  guestIdNumber     String?  @map("guest_id_number")
  nationality       String?
  phone             String?
  numNights         Int      @map("num_nights")
  stayType          String   @default("daily") @map("stay_type")
  checkIn           DateTime @map("check_in") // scheduled check-in
  checkOut          DateTime @map("check_out") // scheduled check-out
  unitPrice         Float    @map("unit_price")
  totalAmount       Float    @map("total_amount")
  paidAmount        Float    @default(0) @map("paid_amount")
  remaining         Float    @default(0)
  paymentMethod     String?  @map("payment_method")
  status            String   @default("active")
  groupId           String?  @map("group_id")
  numGuests         Int      @default(1) @map("num_guests")
  notes             String?
  bedSetupRequested String?  @map("bed_setup_requested") // default | combined | separated (null = no preference)
  createdAt         DateTime @default(now()) @map("created_at")

  // ---- Direct-booking (Phase 2) ----
  /// Channel the reservation came from. Used for reporting and for flagging
  /// rows in the staff UI. Values: staff | direct_web | booking_com | whatsapp
  source           String    @default("staff")
  /// When non-null the row is a short-lived "hold" (status = pending_hold)
  /// created by `/api/book/hold`. Overlap checks exclude holds that have
  /// already expired. Cleared when the hold is confirmed or cancelled.
  holdExpiresAt    DateTime? @map("hold_expires_at")
  /// Short public-facing code shown to the guest once confirmed — e.g.
  /// "FKH-A7B3X". Guests use it to pull up their reservation from /account
  /// or from the confirmation page without authenticating.
  confirmationCode String?   @unique @map("confirmation_code")
  /// Optional link back to the GuestAccount that booked online. null for
  /// staff-entered reservations (the guest may not have an account).
  guestAccountId   Int?      @map("guest_account_id")

  // ---- Hotel-desk operational timestamps ----
  // Captured by front-desk actions (Check-In / Check-Out buttons). These are
  // distinct from `checkIn` / `checkOut`, which remain the *scheduled* window.
  actualCheckInAt  DateTime? @map("actual_check_in_at")
  actualCheckOutAt DateTime? @map("actual_check_out_at")
  checkedInById    Int?      @map("checked_in_by")
  checkedOutById   Int?      @map("checked_out_by")

  // ---- No-show / cancellation metadata ----
  noShow             Boolean   @default(false) @map("no_show")
  noShowAt           DateTime? @map("no_show_at")
  cancellationReason String?   @map("cancellation_reason")
  cancelledAt        DateTime? @map("cancelled_at")
  cancelledById      Int?      @map("cancelled_by")

  unit         Unit                   @relation(fields: [unitId], references: [id])
  guestAccount GuestAccount?          @relation(fields: [guestAccountId], references: [id])
  guests       Guest[]
  transactions Transaction[]
  statusLogs   ReservationStatusLog[]
  extensions   ReservationExtension[]

  @@index([status])
  @@index([actualCheckInAt])
  @@index([source, createdAt])
  @@index([guestAccountId])
  @@index([holdExpiresAt])
  @@map("reservations")
}

/// Append-only log of every reservation extension event. Each row keeps
/// enough "before" state to support a clean reversal (undo) even after
/// multiple extensions, and acts as the authoritative source when the
/// front-desk UI needs to show the history of a stay.
model ReservationExtension {
  id                  Int       @id @default(autoincrement())
  reservationId       Int       @map("reservation_id")
  additionalNights    Int       @map("additional_nights")
  stayType            String    @default("daily") @map("stay_type")
  addedAmount         Float     @map("added_amount")
  addedPaid           Float     @default(0) @map("added_paid")
  paymentMethod       String?   @map("payment_method")
  note                String?
  // Snapshot of the reservation BEFORE this extension was applied — used
  // to restore state on reversal.
  previousCheckOut    DateTime  @map("previous_check_out")
  newCheckOut         DateTime  @map("new_check_out")
  previousNumNights   Int       @map("previous_num_nights")
  newNumNights        Int       @map("new_num_nights")
  previousTotalAmount Float     @map("previous_total_amount")
  newTotalAmount      Float     @map("new_total_amount")
  previousPaidAmount  Float     @map("previous_paid_amount")
  newPaidAmount       Float     @map("new_paid_amount")
  previousStatus      String    @map("previous_status")
  createdById         Int?      @map("created_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  reversedAt          DateTime? @map("reversed_at")
  reversedById        Int?      @map("reversed_by")
  reversalReason      String?   @map("reversal_reason")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("ReservationExtensionCreator", fields: [createdById], references: [id])
  reversedBy  User?       @relation("ReservationExtensionReverser", fields: [reversedById], references: [id])

  @@index([reservationId, createdAt])
  @@index([reversedAt])
  @@map("reservation_extensions")
}

/// Append-only audit trail of every reservation state transition.
/// Consumed by the reservation detail UI and by audit/export reports.
/// Never mutated after insert.
model ReservationStatusLog {
  id            Int      @id @default(autoincrement())
  reservationId Int      @map("reservation_id")
  fromStatus    String   @map("from_status")
  toStatus      String   @map("to_status")
  /// One of:
  ///   check_in | check_out | cancel | no_show | reopen | extend
  ///   auto_activate | auto_complete | edit  (edit = financial repost)
  action        String
  reason        String?
  actorUserId   Int?     @map("actor_user_id")
  at            DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  actor       User?       @relation(fields: [actorUserId], references: [id])

  @@index([reservationId, at])
  @@index([action, at])
  @@map("reservation_status_logs")
}

model Guest {
  id            Int     @id @default(autoincrement())
  reservationId Int     @map("reservation_id")
  guestOrder    Int     @map("guest_order")
  fullName      String  @map("full_name")
  idNumber      String  @map("id_number")
  nationality   String  @default("")
  idDocImage    String? @map("id_doc_image")
  notes         String?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("guests")
}

// ============================================================================
// Guest accounts (direct booking — Phase 1)
// ============================================================================
//
// Intentionally separate from `User` (staff) so the admin RBAC system stays
// clean: guests have no role / no permissions — only ownership of their own
// reservations. NextAuth has a dedicated "guest-credentials" provider that
// reads this table and a JWT `audience: "guest"` claim to distinguish the
// two audiences in middleware.

model GuestAccount {
  id              Int       @id @default(autoincrement())
  /// E.164 digits without the leading "+" (e.g. "962781099910"). Optional —
  /// social-only signups (Google/Apple) start without a phone, then link one
  /// via OTP later (see /account/complete-profile + GuestAccountIdentity).
  /// Once set, it is the primary identifier for both messaging (WhatsApp OTP)
  /// and the phone-credentials login flow.
  phone           String?   @unique
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  email           String?   @unique
  emailVerifiedAt DateTime? @map("email_verified_at")
  /// Optional — guests created via OTP-only signup or social providers do not
  /// have a password. Legacy accounts created before April 2026 still have it.
  passwordHash    String?   @map("password_hash")
  fullName        String    @map("full_name")
  nationality     String?
  idNumber        String?   @map("id_number")
  idDocImage      String?   @map("id_doc_image")
  preferredLang   String    @default("ar") @map("preferred_lang") // ar | en
  avatarUrl       String?   @map("avatar_url")
  disabledAt      DateTime? @map("disabled_at")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  reservations     Reservation[]
  identities       GuestAccountIdentity[]
  botConversations BotConversation[]

  @@index([createdAt])
  @@map("guest_accounts")
}

/// One row per (provider, providerId) tuple authenticating a `GuestAccount`.
/// A single guest can have multiple identities — e.g. "phone" + "google" +
/// "apple" — all pointing to the same logical account. This is how we keep
/// a guest from accidentally creating duplicate accounts when they sign in
/// once with Google and later with their phone number.
///
/// Provider values:
///   • "phone"   → providerId = E.164 digits (mirrors GuestAccount.phone)
///   • "google"  → providerId = Google `sub` claim (stable, unique)
///   • "apple"   → providerId = Apple `sub` claim (stable, unique)
model GuestAccountIdentity {
  id             Int      @id @default(autoincrement())
  guestAccountId Int      @map("guest_account_id")
  provider       String
  providerId     String   @map("provider_id")
  /// Email reported by the provider at sign-in. For Apple, this is often a
  /// `privaterelay.appleid.com` alias rather than the user's real address.
  email          String?
  emailVerified  Boolean  @default(false) @map("email_verified")
  createdAt      DateTime @default(now()) @map("created_at")
  lastUsedAt     DateTime @default(now()) @map("last_used_at")

  guestAccount GuestAccount @relation(fields: [guestAccountId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([guestAccountId])
  @@map("guest_account_identities")
}

/// Short-lived one-time passwords used for guest phone-verification flows:
/// signup (own the phone), passwordless login, password reset, or
/// change-phone. Codes are stored bcrypt-hashed; the plain code is sent
/// only via WhatsApp.
model GuestOtp {
  id         Int       @id @default(autoincrement())
  phone      String
  /// Scrypt/bcrypt hash of the 6-digit code. Never store plain codes.
  codeHash   String    @map("code_hash")
  /// signup | login | reset | change_phone
  purpose    String
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  attempts   Int       @default(0)
  ip         String?
  createdAt  DateTime  @default(now()) @map("created_at")

  /// Random per-request UUID also stored in the requesting browser as the
  /// `wa_intent` cookie. Lets the polling endpoint scope itself to the same
  /// browser that initiated the OTP, preventing cross-browser hijacks of an
  /// in-flight verification.
  intentId      String?   @map("intent_id")
  /// Set when the user taps the WhatsApp magic-link (Click-to-Login). Once
  /// set, `/api/guest-auth/otp/poll` returns a usable signupToken so the
  /// originating browser can complete sign-in without retyping the code.
  magicTappedAt DateTime? @map("magic_tapped_at")

  @@index([phone, purpose, expiresAt])
  @@index([expiresAt])
  @@index([intentId])
  @@map("guest_otps")
}

/// DEPRECATED: legacy per-category pricing. Kept for backward-compat while
/// migrating to UnitTypePrice (Phase 5). Will be removed after full migration.
model SeasonalPrice {
  id          Int      @id @default(autoincrement())
  seasonName  String   @map("season_name")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  roomDaily   Float    @map("room_daily")
  roomWeekly  Float    @map("room_weekly")
  roomMonthly Float    @map("room_monthly")
  aptDaily    Float    @map("apt_daily")
  aptWeekly   Float    @map("apt_weekly")
  aptMonthly  Float    @map("apt_monthly")

  seasonId Int?    @map("season_id")
  season   Season? @relation(fields: [seasonId], references: [id])

  @@map("seasonal_prices")
}

/// A date range used to group per-unit-type prices (high/low/Ramadan, etc.).
model Season {
  id        Int      @id @default(autoincrement())
  nameAr    String   @map("name_ar")
  nameEn    String?  @map("name_en")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  prices         UnitTypePrice[]
  seasonalPrices SeasonalPrice[]

  @@index([startDate, endDate])
  @@map("seasons")
}

/// Per-unit-type price for a given season. One row per (unitType × season).
model UnitTypePrice {
  id         Int   @id @default(autoincrement())
  unitTypeId Int   @map("unit_type_id")
  seasonId   Int   @map("season_id")
  daily      Float @default(0)
  weekly     Float @default(0)
  monthly    Float @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  unitType UnitType @relation(fields: [unitTypeId], references: [id], onDelete: Cascade)
  season   Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([unitTypeId, seasonId])
  @@index([seasonId])
  @@map("unit_type_prices")
}

model Maintenance {
  id             Int       @id @default(autoincrement())
  unitId         Int       @map("unit_id")
  description    String
  contractor     String?
  cost           Float     @default(0)
  status         String    @default("pending")
  requestDate    DateTime  @default(now()) @map("request_date")
  completionDate DateTime? @map("completion_date")
  notes          String?

  unit Unit  @relation(fields: [unitId], references: [id])
  task Task?

  @@map("maintenance")
}

model Transaction {
  id            Int      @id @default(autoincrement())
  date          DateTime
  description   String
  reservationId Int?     @map("reservation_id")
  amount        Float
  type          String
  account       String
  bankRef       String?  @map("bank_ref")
  createdAt     DateTime @default(now()) @map("created_at")

  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@map("transactions")
}

// ============================================================================
// Double-Entry Accounting Models
// ============================================================================

model Account {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  type          String // asset | liability | equity | revenue | expense
  subtype       String? // cash | bank | ar | ap | capital | drawing | ...
  normalBalance String   @map("normal_balance") // debit | credit
  parentId      Int?     @map("parent_id")
  isSystem      Boolean  @default(false) @map("is_system")
  isActive      Boolean  @default(true) @map("is_active")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  parent    Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children  Account[]     @relation("AccountTree")
  lines     JournalLine[]
  partiesAR Party[]       @relation("ARAccount")
  partiesAP Party[]       @relation("APAccount")
  partiesEq Party[]       @relation("EquityAccount")
  partiesDr Party[]       @relation("DrawAccount")

  payrollDeductions PayrollDeduction[]

  @@index([type])
  @@index([parentId])
  @@map("accounts")
}

model Party {
  id              Int       @id @default(autoincrement())
  code            String?   @unique
  name            String
  type            String // guest | partner | supplier | employee | lender | other
  phone           String?
  email           String?
  nationalId      String?   @map("national_id")
  notes           String?
  isActive        Boolean   @default(true) @map("is_active")
  openingBalance  Float     @default(0) @map("opening_balance")
  openingDate     DateTime? @map("opening_date")
  arAccountId     Int?      @map("ar_account_id")
  apAccountId     Int?      @map("ap_account_id")
  equityAccountId Int?      @map("equity_account_id")
  drawAccountId   Int?      @map("draw_account_id")

  // ---- Employee-specific fields (used when type = 'employee') ----
  baseSalary      Float?    @map("base_salary")
  commissionRate  Float?    @map("commission_rate") // e.g. 0.05 = 5% of rental revenue
  salaryPayDay    Int?      @map("salary_pay_day") // day of month (1-28) when salary is due
  hireDate        DateTime? @map("hire_date")
  terminationDate DateTime? @map("termination_date")
  jobTitle        String?   @map("job_title")

  createdAt DateTime @default(now()) @map("created_at")

  arAccount     Account?      @relation("ARAccount", fields: [arAccountId], references: [id])
  apAccount     Account?      @relation("APAccount", fields: [apAccountId], references: [id])
  equityAccount Account?      @relation("EquityAccount", fields: [equityAccountId], references: [id])
  drawAccount   Account?      @relation("DrawAccount", fields: [drawAccountId], references: [id])
  lines         JournalLine[]

  payrollDeductions            PayrollDeduction[]
  payrollDeductionApplications PayrollDeductionApplication[]

  @@index([type])
  @@index([isActive])
  @@map("parties")
}

model JournalEntry {
  id           Int       @id @default(autoincrement())
  entryNumber  String    @unique @map("entry_number")
  date         DateTime
  description  String
  reference    String?
  source       String // manual | reservation | payment | expense | salary | opening | reversal
  sourceRefId  Int?      @map("source_ref_id")
  status       String    @default("posted") // draft | posted | void
  totalDebit   Float     @map("total_debit")
  totalCredit  Float     @map("total_credit")
  createdById  Int?      @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  voidedAt     DateTime? @map("voided_at")
  voidedById   Int?      @map("voided_by")
  voidReason   String?   @map("void_reason")
  reversalOfId Int?      @map("reversal_of_id")

  lines       JournalLine[]
  attachments JournalAttachment[]
  reversalOf  JournalEntry?       @relation("Reversal", fields: [reversalOfId], references: [id])
  reversedBy  JournalEntry[]      @relation("Reversal")

  @@index([date])
  @@index([source, sourceRefId])
  @@index([status])
  @@map("journal_entries")
}

// Optional supporting documents for a journal entry — original supplier
// invoice, electricity bill, payment receipt, etc. Multiple files per entry,
// stored on the shared uploads volume; only metadata lives here.
model JournalAttachment {
  id           Int      @id @default(autoincrement())
  entryId      Int      @map("entry_id")
  fileName     String   @map("file_name")
  mimeType     String   @map("mime_type")
  size         Int
  storagePath  String   @map("storage_path")
  caption      String? // free-text label e.g. "أصل الفاتورة" or "إيصال التحويل"
  uploadedById Int?     @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  entry JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@map("journal_attachments")
}

model JournalLine {
  id           Int     @id @default(autoincrement())
  entryId      Int     @map("entry_id")
  accountId    Int     @map("account_id")
  partyId      Int?    @map("party_id")
  costCenterId Int?    @map("cost_center_id")
  debit        Float   @default(0)
  credit       Float   @default(0)
  description  String?
  lineOrder    Int     @map("line_order")

  entry      JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account    Account      @relation(fields: [accountId], references: [id])
  party      Party?       @relation(fields: [partyId], references: [id])
  costCenter CostCenter?  @relation(fields: [costCenterId], references: [id])

  @@index([entryId])
  @@index([accountId])
  @@index([partyId])
  @@index([costCenterId])
  @@map("journal_lines")
}

// ============================================================================
// Cost Centers (مراكز التكلفة)
// ============================================================================
//
// Analytical dimension layered on top of the chart of accounts. Lets the
// business slice expenses/revenues by department, project, building, branch,
// or any custom hierarchy without polluting the COA. Each `JournalLine` may
// optionally reference one cost center so reports can aggregate
// debit/credit totals per center.
//
// Hierarchy is supported via `parentId` (e.g. "العمليات" → "الاستقبال")
// so reports can roll up nested centers.
model CostCenter {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  parentId    Int?     @map("parent_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  parent   CostCenter?   @relation("CostCenterTree", fields: [parentId], references: [id])
  children CostCenter[]  @relation("CostCenterTree")
  lines    JournalLine[]

  @@index([parentId])
  @@index([isActive])
  @@map("cost_centers")
}

model FiscalPeriod {
  id       Int       @id @default(autoincrement())
  year     Int
  month    Int
  status   String    @default("open") // open | closed
  closedAt DateTime? @map("closed_at")
  closedBy Int?      @map("closed_by")

  @@unique([year, month])
  @@map("fiscal_periods")
}

model AccountingCounter {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value Int    @default(0)

  @@map("accounting_counters")
}

// ============================================================================
// Payroll Deductions (continuous & installment)
// ============================================================================
//
// Represents a recurring or installment-based salary deduction configured
// per employee (e.g. health insurance, court order, work-permit fee).
//
// Calculation models supported:
//   • fixed         — flat monthly amount (`amount`)
//   • percent_gross — `percent` × (basic + commission) each month
//   • percent_net   — `percent` × (gross − all earlier deductions) each month
//
// Modes:
//   • continuous    — applied every month within the [start, end?] window
//   • installment   — applied each month until cumulative applied
//                     reaches `totalAmount` (then auto-deactivates)
//
// `liabilityAccountId` is the credit-side GL account when the salary is
// posted. If null, the post route falls back to the system "خصومات راتب
// أخرى" account (2150).
model PayrollDeduction {
  id       Int    @id @default(autoincrement())
  partyId  Int    @map("party_id")
  name     String
  category String @default("other") // insurance | permit | court | loan | other

  calcType String @map("calc_type") // fixed | percent_gross | percent_net
  amount   Float? // for fixed
  percent  Float? // for percent_gross | percent_net (0..1, e.g. 0.05 = 5%)

  mode        String @default("continuous") // continuous | installment
  totalAmount Float? @map("total_amount") // installment cap (full debt to recover)

  startYear  Int  @map("start_year")
  startMonth Int  @map("start_month") // 1..12
  endYear    Int? @map("end_year")
  endMonth   Int? @map("end_month")

  liabilityAccountId Int? @map("liability_account_id")

  priority Int     @default(100) // tiebreaker within same calcType
  isActive Boolean @default(true) @map("is_active")
  notes    String?

  createdById Int?     @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  party            Party                         @relation(fields: [partyId], references: [id], onDelete: Cascade)
  liabilityAccount Account?                      @relation(fields: [liabilityAccountId], references: [id])
  applications     PayrollDeductionApplication[]

  @@index([partyId, isActive])
  @@index([category])
  @@map("payroll_deductions")
}

// One row per (deduction, year, month) recorded when the salary is posted.
// Provides:
//   • idempotency (unique on deductionId+year+month)
//   • audit link to the salary payment JournalEntry
//   • basis for installment-progress queries
model PayrollDeductionApplication {
  id             Int      @id @default(autoincrement())
  deductionId    Int      @map("deduction_id")
  partyId        Int      @map("party_id")
  year           Int
  month          Int // 1..12
  appliedAmount  Float    @map("applied_amount")
  journalEntryId Int?     @map("journal_entry_id")
  createdAt      DateTime @default(now()) @map("created_at")

  deduction PayrollDeduction @relation(fields: [deductionId], references: [id], onDelete: Cascade)
  party     Party            @relation(fields: [partyId], references: [id])

  @@unique([deductionId, year, month])
  @@index([partyId, year, month])
  @@map("payroll_deduction_applications")
}

// ============================================================================
// Permissions / RBAC
// ============================================================================

model Resource {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  label       String
  category    String   @default("general")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  permissions Permission[]

  @@index([category])
  @@map("resources")
}

model Permission {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  resourceId Int      @map("resource_id")
  action     String
  label      String
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  resource        Resource                 @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userOverrides   UserPermissionOverride[]

  @@unique([resourceId, action])
  @@index([action])
  @@map("permissions")
}

model Role {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model UserPermissionOverride {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  permissionId Int      @map("permission_id")
  effect       String // allow | deny
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
  @@map("user_permission_overrides")
}

// ============================================================================
// Tasks Module (Kanban)
// ============================================================================

model TaskBoard {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  color       String? // hex color for UI accent
  ownerId     Int       @map("owner_id")
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  owner   User              @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members TaskBoardMember[]
  columns TaskColumn[]
  tasks   Task[]
  labels  TaskLabel[]

  @@index([ownerId])
  @@index([archivedAt])
  @@map("task_boards")
}

model TaskBoardMember {
  id        Int      @id @default(autoincrement())
  boardId   Int      @map("board_id")
  userId    Int      @map("user_id")
  role      String   @default("editor") // owner | editor | viewer
  createdAt DateTime @default(now()) @map("created_at")

  board TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
  @@map("task_board_members")
}

model TaskColumn {
  id        Int      @id @default(autoincrement())
  boardId   Int      @map("board_id")
  name      String
  position  Int
  wipLimit  Int?     @map("wip_limit")
  createdAt DateTime @default(now()) @map("created_at")

  board TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId, position])
  @@map("task_columns")
}

model Task {
  id            Int       @id @default(autoincrement())
  boardId       Int       @map("board_id")
  columnId      Int       @map("column_id")
  title         String
  description   String?
  priority      String    @default("med") // low | med | high | urgent
  dueAt         DateTime? @map("due_at")
  startAt       DateTime? @map("start_at")
  position      Int
  createdById   Int       @map("created_by")
  archivedAt    DateTime? @map("archived_at")
  completedAt   DateTime? @map("completed_at")
  maintenanceId Int?      @unique @map("maintenance_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  board         TaskBoard           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column        TaskColumn          @relation(fields: [columnId], references: [id])
  createdBy     User                @relation("TaskCreator", fields: [createdById], references: [id])
  maintenance   Maintenance?        @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)
  assignees     TaskAssignee[]
  labels        TaskLabelOnTask[]
  checklist     TaskChecklistItem[]
  attachments   TaskAttachment[]
  comments      TaskComment[]
  activities    TaskActivity[]
  conversations ChatConversation[]  @relation("TaskConversations")

  @@index([boardId, columnId, position])
  @@index([dueAt])
  @@index([completedAt])
  @@map("tasks")
}

model TaskAssignee {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model TaskLabel {
  id      Int    @id @default(autoincrement())
  boardId Int    @map("board_id")
  name    String
  color   String @default("#6b7280")

  board TaskBoard         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks TaskLabelOnTask[]

  @@index([boardId])
  @@map("task_labels")
}

model TaskLabelOnTask {
  taskId  Int @map("task_id")
  labelId Int @map("label_id")

  task  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
  @@map("task_label_on_task")
}

model TaskChecklistItem {
  id       Int     @id @default(autoincrement())
  taskId   Int     @map("task_id")
  text     String
  done     Boolean @default(false)
  position Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, position])
  @@map("task_checklist_items")
}

model TaskAttachment {
  id           Int      @id @default(autoincrement())
  taskId       Int      @map("task_id")
  fileName     String   @map("file_name")
  mimeType     String   @map("mime_type")
  size         Int
  storagePath  String   @map("storage_path")
  uploadedById Int      @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("TaskAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([taskId])
  @@map("task_attachments")
}

model TaskComment {
  id        Int       @id @default(autoincrement())
  taskId    Int       @map("task_id")
  authorId  Int       @map("author_id")
  body      String
  createdAt DateTime  @default(now()) @map("created_at")
  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_comments")
}

model TaskActivity {
  id          Int      @id @default(autoincrement())
  taskId      Int      @map("task_id")
  actorId     Int      @map("actor_id")
  type        String // created | moved | assigned | unassigned | updated | completed | reopened | label_added | label_removed | attachment | commented
  payloadJson Json?    @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User @relation(fields: [actorId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_activities")
}

// ============================================================================
// Chat Module
// ============================================================================

model ChatConversation {
  id            Int       @id @default(autoincrement())
  type          String // dm | group | task
  title         String?
  taskId        Int?      @map("task_id")
  createdById   Int       @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastMessageAt DateTime? @map("last_message_at")

  task         Task?             @relation("TaskConversations", fields: [taskId], references: [id], onDelete: SetNull)
  createdBy    User              @relation("ConversationCreator", fields: [createdById], references: [id])
  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([taskId])
  @@index([lastMessageAt])
  @@map("chat_conversations")
}

model ChatParticipant {
  id             Int       @id @default(autoincrement())
  conversationId Int       @map("conversation_id")
  userId         Int       @map("user_id")
  role           String    @default("member") // admin | member
  lastReadAt     DateTime? @map("last_read_at")
  mutedUntil     DateTime? @map("muted_until")
  joinedAt       DateTime  @default(now()) @map("joined_at")
  leftAt         DateTime? @map("left_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model ChatMessage {
  id             Int       @id @default(autoincrement())
  conversationId Int       @map("conversation_id")
  senderId       Int       @map("sender_id")
  body           String
  replyToId      Int?      @map("reply_to_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  editedAt       DateTime? @map("edited_at")
  deletedAt      DateTime? @map("deleted_at")

  conversation ChatConversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                    @relation(fields: [senderId], references: [id])
  replyTo      ChatMessage?            @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      ChatMessage[]           @relation("MessageReplies")
  attachments  ChatMessageAttachment[]
  reactions    ChatReaction[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

model ChatMessageAttachment {
  id           Int      @id @default(autoincrement())
  messageId    Int      @map("message_id")
  fileName     String   @map("file_name")
  mimeType     String   @map("mime_type")
  size         Int
  storagePath  String   @map("storage_path")
  uploadedById Int      @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedBy User        @relation("ChatAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([messageId])
  @@map("chat_message_attachments")
}

model ChatReaction {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  userId    Int      @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("chat_reactions")
}

// ============================================================================
// Notifications
// ============================================================================

model Notification {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  /// Event code, e.g. "task.assigned", "reservation.created", "chat.mention".
  /// Used as a reference both into `events.ts` registry (for icon + label
  /// fallbacks) and into `NotificationPreference` rows (per-event toggles).
  type         String
  title        String
  body         String?
  linkUrl      String?   @map("link_url")
  payloadJson  Json?     @map("payload_json")
  /// Bucketing for the notification-center UI tabs and the preferences
  /// accordion. Mirrors `events.ts → category`. Examples:
  ///   reservations | tasks | chat | whatsapp | finance | accounting |
  ///   maintenance | system | security
  category     String?
  /// 0 = normal, 1 = high, 2 = urgent. Drives the colored "عاجل" pill in
  /// the center and overrides quiet-hours rules.
  priority     Int       @default(0)
  readAt       DateTime? @map("read_at")
  /// Set when the user archives the row from the center. Archived rows
  /// hide from "all" / "unread" tabs but stay queryable for retention.
  archivedAt   DateTime? @map("archived_at")
  /// Future timestamp until which this notification should be hidden from
  /// the bell + center. The list query filters out rows with snoozedUntil
  /// in the future (so a snoozed row reappears automatically).
  snoozedUntil DateTime? @map("snoozed_until")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
  @@index([userId, archivedAt])
  @@index([userId, category, createdAt])
  @@map("notifications")
}

/// Per-user preferences for notification delivery.
///
/// Two row shapes coexist in the same table:
///   1. **Channel master** rows where `eventCode = "*"` — one per channel
///      per user. Setting `isEnabled=false` mutes the channel for every
///      event regardless of per-event rows. Quiet-hours / timezone are
///      stored on the in_app master row (`*` + `in_app`).
///   2. **Per-event** rows where `eventCode` matches an entry in
///      `events.ts`. They override the default delivery channels declared
///      by the event (e.g. user wants `task.assigned` over WhatsApp too).
///
/// `digestMode` controls batching for non-urgent rows: instant | hourly |
/// daily | weekly. `quiet_hours_start` / `quiet_hours_end` are HH:mm
/// strings stored in the user's IANA `timezone` (default Asia/Amman).
model NotificationPreference {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  /// Event code from `events.ts`, or "*" for the channel-master row.
  eventCode       String   @map("event_code")
  /// "in_app" | "email" | "whatsapp" | "web_push" | "sound"
  channel         String
  isEnabled       Boolean  @default(true) @map("is_enabled")
  digestMode      String   @default("instant") @map("digest_mode")
  quietHoursStart String?  @map("quiet_hours_start")
  quietHoursEnd   String?  @map("quiet_hours_end")
  timezone        String   @default("Asia/Amman")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventCode, channel])
  @@index([userId])
  @@map("notification_preferences")
}

// ============================================================================
// Booking.com integration (Phase 6)
// ============================================================================
//
// We don't use a third-party Channel Manager. Instead, a separate Node process
// (see bot/) drives Booking.com Extranet via Playwright. These tables are the
// contract between the web app (reads/writes jobs) and the bot (consumes them).
// Credentials are stored encrypted (AES-GCM) — never logged, never exposed.

/// Encrypted login credentials for Booking.com Extranet. One row per account.
model BookingCredential {
  id             Int       @id @default(autoincrement())
  label          String // e.g. "Main property"
  email          String
  passwordEnc    String    @map("password_enc") // base64(iv|tag|ciphertext)
  twoFaSecretEnc String?   @map("two_fa_secret_enc") // optional TOTP secret (encrypted)
  propertyId     String?   @map("property_id") // Booking property id (digits)
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginOk    Boolean?  @map("last_login_ok")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("booking_credentials")
}

/// Maps a local Unit (or UnitType) to its Booking.com room type/id.
/// We support two granularities: unitId (specific room) and unitTypeId (group).
model BookingPropertyMap {
  id               Int       @id @default(autoincrement())
  unitId           Int?      @unique @map("unit_id")
  unitTypeId       Int?      @unique @map("unit_type_id")
  extranetRoomId   String    @map("extranet_room_id")
  extranetRoomName String?   @map("extranet_room_name")
  extranetRoomCode String?   @map("extranet_room_code")
  lastSyncedAt     DateTime? @map("last_synced_at")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([unitId])
  @@index([unitTypeId])
  @@map("booking_property_map")
}

/// A unit of work for the bot. The web API enqueues jobs; the bot polls & runs.
model BookingSyncJob {
  id          Int       @id @default(autoincrement())
  type        String // login_check | push_prices | push_availability | pull_reservations
  status      String    @default("pending") // pending | running | done | failed | cancelled
  scheduledAt DateTime  @default(now()) @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  attempts    Int       @default(0)
  payloadJson Json?     @map("payload_json") // e.g. { seasonId, unitTypeIds, fromDate, toDate }
  resultJson  Json?     @map("result_json") // summary counts, timing
  error       String?
  createdBy   Int?      @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  logs BookingSyncLog[]

  @@index([status, scheduledAt])
  @@index([type, createdAt])
  @@map("booking_sync_jobs")
}

/// Append-only log stream for a job. Bot writes, UI reads.
model BookingSyncLog {
  id       Int      @id @default(autoincrement())
  jobId    Int      @map("job_id")
  ts       DateTime @default(now())
  level    String   @default("info") // info | warn | error
  message  String
  metaJson Json?    @map("meta_json")

  job BookingSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, ts])
  @@map("booking_sync_logs")
}

/// Inbox for reservations pulled from Booking before they are imported into
/// our own Reservation table (giving a human the chance to confirm mapping).
model BookingInboxReservation {
  id                 Int       @id @default(autoincrement())
  externalId         String    @unique @map("external_id") // Booking reservation number
  guestName          String    @map("guest_name")
  guestEmail         String?   @map("guest_email")
  guestPhone         String?   @map("guest_phone")
  checkIn            DateTime  @map("check_in")
  checkOut           DateTime  @map("check_out")
  extranetRoomId     String?   @map("extranet_room_id")
  mappedUnitId       Int?      @map("mapped_unit_id")
  numGuests          Int       @default(1) @map("num_guests")
  totalAmount        Float     @default(0) @map("total_amount")
  currency           String    @default("JOD")
  status             String    @default("new") // new | imported | ignored | conflict
  rawJson            Json?     @map("raw_json")
  localReservationId Int?      @map("local_reservation_id")
  importedAt         DateTime? @map("imported_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([checkIn, checkOut])
  @@map("booking_inbox_reservations")
}

// ============================================================================
// WhatsApp Business Cloud API integration
// ============================================================================

/// Singleton row holding the active WhatsApp Business Cloud API credentials.
/// We keep exactly one row (enforced in code) — `id = 1` — and store the
/// access token encrypted with the shared AES-256-GCM helper so it is never
/// exposed in logs/backups in plaintext.
model WhatsAppConfig {
  id                 Int     @id @default(1)
  appId              String? @map("app_id")
  /// App Secret is needed to verify webhook signatures (X-Hub-Signature-256).
  appSecretEnc       String? @map("app_secret_enc")
  wabaId             String? @map("waba_id")
  phoneNumberId      String? @map("phone_number_id")
  displayPhoneNumber String? @map("display_phone_number")
  /// System-User permanent token. Never returned to the client unmasked.
  accessTokenEnc     String? @map("access_token_enc")
  webhookVerifyToken String? @map("webhook_verify_token")
  apiVersion         String  @default("v21.0") @map("api_version")
  isActive           Boolean @default(true) @map("is_active")

  // ---- Booking-confirmation auto-send (Phase 3) ----
  /// When true, every successful POST /api/reservations triggers a fire-
  /// and-forget WhatsApp dispatch: approved template + auto-generated
  /// contract PDF + the optional welcome caption below.
  autoSendBookingConfirmation Boolean @default(false) @map("auto_send_booking_confirmation")
  /// Approved template name used for the auto dispatch. Defaults to
  /// "booking_confirmation_ar" but operators can rebind to any UTILITY
  /// template they have approved.
  bookingConfirmationTemplate String  @default("booking_confirmation_ar") @map("booking_confirmation_template")
  bookingConfirmationLanguage String  @default("ar") @map("booking_confirmation_language")
  /// Free-text caption attached to the contract PDF when delivered as a
  /// follow-up document (header is TEXT and not DOCUMENT). May contain
  /// the same {{1}}..{{N}} placeholders as the template body — they are
  /// substituted with the same reservation facts.
  bookingConfirmationCaption  String? @map("booking_confirmation_caption")

  /// When true, after the structured confirmation + PDF are delivered we
  /// send an additional free-text message (within the now-open 24-hour
  /// customer-service window) that contains a tasteful Quranic / Sunnah
  /// blessing — matches the religious section already printed on the
  /// physical contract. Operator can disable or rewrite the text below.
  bookingFollowUpEnabled Boolean @default(true) @map("booking_follow_up_enabled")
  /// Free-text follow-up message (Quranic art / Sunnah). Supports the
  /// same {{1}}..{{N}} substitutions for personalisation.
  bookingFollowUpText    String? @map("booking_follow_up_text")

  // ---- AI Concierge bot ("WhatsApp Booking Bot") — Phase 0+ ----
  /// Master switch + rollout strategy.
  ///   "off"        = bot is fully disabled (current behaviour).
  ///   "shadow"     = bot processes every inbound and writes a draft to
  ///                  `bot_shadow_drafts`, but never sends to the guest.
  ///                  Staff approve/edit/ignore from the inbox UI.
  ///   "allowlist"  = bot replies only when the contact phone is present in
  ///                  `bot_allowlist`. All other contacts go through the
  ///                  unchanged inbox + auto-reply path.
  ///   "percentage" = bot replies for `botRolloutPercentage`% of contacts,
  ///                  partitioned deterministically by hash(phone). The same
  ///                  guest always gets the same experience.
  ///   "full"       = bot replies for every eligible inbound.
  /// In every mode except "off" the kill-switch is a single UPDATE.
  botMode                   String    @default("off") @map("bot_mode")
  /// 0..100 — only consulted when `botMode = "percentage"`.
  botRolloutPercentage      Int       @default(0) @map("bot_rollout_percentage")
  /// Persona name surfaced inside the system prompt ("أنت محمد...").
  botPersonaName            String    @default("محمد") @map("bot_persona_name")
  /// "warm" | "formal" | "playful" — feeds the system prompt tone.
  botPersonaTone            String    @default("warm") @map("bot_persona_tone")
  /// LLM provider id: "openai" | "gemini" | "anthropic".
  botLlmProvider            String    @default("openai") @map("bot_llm_provider")
  /// Concrete model slug for the chosen provider (e.g. "gpt-4o-mini").
  botLlmModel               String    @default("gpt-4o-mini") @map("bot_llm_model")
  /// Encrypted LLM API key (never returned to the client unmasked).
  botLlmApiKeyEnc           String?   @map("bot_llm_api_key_enc")
  /// Hard cap on tool-call hops per inbound message (anti-runaway).
  botMaxToolHops            Int       @default(5) @map("bot_max_tool_hops")
  /// Hard cap on user/assistant turn pairs kept in the LLM context.
  botMaxTurns               Int       @default(12) @map("bot_max_turns")
  /// USD spending budget per UTC day. Circuit-breaker kicks in when crossed.
  botDailyBudgetUsd         Decimal   @default(5) @map("bot_daily_budget_usd") @db.Decimal(8, 2)
  /// Running total for the current day; reset by `botCostResetAt`.
  botCostTodayUsd           Decimal   @default(0) @map("bot_cost_today_usd") @db.Decimal(8, 4)
  botCostResetAt            DateTime? @map("bot_cost_reset_at")
  /// When true, automatic circuit breakers (escalation rate, budget, etc.)
  /// can downgrade `botMode` to "shadow" without human intervention.
  botCircuitBreakerEnabled  Boolean   @default(true) @map("bot_circuit_breaker_enabled")
  /// Optional opening-hours window in Asia/Amman, "HH:mm" strings. Outside
  /// this window the bot escalates to human immediately. Null = 24/7.
  botActiveHoursStart       String?   @map("bot_active_hours_start")
  botActiveHoursEnd         String?   @map("bot_active_hours_end")
  /// When true, sender splits long messages and adds typing-style pacing.
  botHumanlikePacing        Boolean   @default(true) @map("bot_humanlike_pacing")
  /// Default Stripe payment currency code (uppercase). The booking engine
  /// computes amounts in JOD; this controls the actual Checkout charge.
  botPaymentCurrency        String    @default("JOD") @map("bot_payment_currency")
  /// Encrypted Stripe secret key. Never returned to the client unmasked.
  botStripeSecretKeyEnc     String?   @map("bot_stripe_secret_key_enc")
  /// Encrypted Stripe webhook signing secret (whsec_...).
  botStripeWebhookSecretEnc String?   @map("bot_stripe_webhook_secret_enc")
  /// Public origin used when constructing Stripe success/cancel URLs.
  botPublicBaseUrl          String?   @map("bot_public_base_url")

  lastVerifiedAt DateTime? @map("last_verified_at")
  lastVerifyOk   Boolean?  @map("last_verify_ok")
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("whatsapp_config")
}

/// A WhatsApp message — inbound or outbound — logged for the inbox UI and
/// for audit/compliance. Threaded by the contact E.164 phone number so we
/// can also join against Reservation.phone / Guest without a formal FK.
model WhatsAppMessage {
  id              Int       @id @default(autoincrement())
  /// "inbound" (from customer) | "outbound" (from hotel)
  direction       String
  /// Meta message ID (wamid.xxxx) — unique per message, used for dedupe.
  wamid           String?   @unique
  /// E.164 contact phone (no "+"). For outbound = to, for inbound = from.
  contactPhone    String    @map("contact_phone")
  /// Display name of the WhatsApp profile (inbound only).
  contactName     String?   @map("contact_name")
  /// "text" | "image" | "document" | "template" | "audio" | "video" | "sticker" | "location" | "interactive" | "reaction" | "unknown"
  type            String    @default("text")
  /// Plain text body (for text messages OR the caption of media messages).
  body            String?
  /// When type="template", the template name used for the outbound send.
  templateName    String?   @map("template_name")
  /// Raw payload (Meta webhook message or send-response) for forensics.
  rawJson         Json?     @map("raw_json")
  /// Lifecycle for outbound: "queued" | "sent" | "delivered" | "read" | "failed".
  /// For inbound, usually "received".
  status          String    @default("queued")
  errorCode       String?   @map("error_code")
  errorMessage    String?   @map("error_message")
  /// Meta pricing category — passed through from the statuses webhook.
  pricingCategory String?   @map("pricing_category")
  /// When Meta marked the message sent / delivered / read.
  sentAt          DateTime? @map("sent_at")
  deliveredAt     DateTime? @map("delivered_at")
  readAt          DateTime? @map("read_at")
  /// Optional soft-link to a reservation (resolved on send / on inbound by phone match).
  reservationId   Int?      @map("reservation_id")
  /// Who triggered the send (for outbound). Null for webhook-originated rows.
  sentByUserId    Int?      @map("sent_by_user_id")
  /// Soft link to the conversation thread. Nullable for historical rows; the
  /// backfill script fills it for every existing message.
  conversationId  Int?      @map("conversation_id")
  /// Reserved for a future "internal note" UX — never sent to Meta.
  isInternalNote  Boolean   @default(false) @map("is_internal_note")
  /// Meta Media ID — for inbound image/video/audio/document/sticker we proxy
  /// downloads through `/api/whatsapp/media/[id]`. For outbound media we also
  /// keep the id so the preview survives restarts. Null for text messages.
  mediaId         String?   @map("media_id")
  /// image/jpeg, image/png, video/mp4, audio/ogg, application/pdf, …
  mediaMimeType   String?   @map("media_mime_type")
  /// Original filename (documents) or generated name (images/videos).
  mediaFilename   String?   @map("media_filename")
  /// SHA-256 hex returned by Meta — handy for dedupe / audit.
  mediaSha256     String?   @map("media_sha256")
  /// Byte size (best-effort — set from Content-Length during download).
  mediaSize       Int?      @map("media_size")
  createdAt       DateTime  @default(now()) @map("created_at")

  conversation WhatsAppConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  shadowDraft  BotShadowDraft?

  @@index([contactPhone, createdAt])
  @@index([direction, status])
  @@index([reservationId])
  @@index([conversationId, createdAt])
  @@index([mediaId])
  @@map("whatsapp_messages")
}

/// A keyword-based auto-reply rule. Evaluated in order of `priority` when an
/// inbound WhatsApp text arrives; the first match fires a reply. Only runs
/// when the conversation is within the 24h customer-service window and not
/// muted, to avoid Meta policy violations.
model WhatsAppAutoReplyRule {
  id              Int       @id @default(autoincrement())
  /// Human-readable label shown in the admin UI.
  name            String
  /// "keyword" (default): contains, case-insensitive.
  /// "exact": whole-message equality (trimmed, case-insensitive).
  /// "regex": JS regex source (sandboxed with 1 s timeout in the engine).
  /// "welcome": no text match — fires only on the first inbound message
  /// of a new conversation (customer's first contact).
  /// "away": fires only outside business hours (quietHoursStart/End).
  matchMode       String    @default("keyword") @map("match_mode")
  /// Pipe-separated triggers for keyword/exact/regex modes ("سعر|الأسعار|price").
  triggers        String    @default("")
  /// Plain-text reply. Interpolation: {{contactName}} {{firstName}} {{hotelName}}.
  replyText       String    @map("reply_text")
  /// Optional approved template name — if set, sent instead of `replyText`
  /// so the rule can fire even outside the 24h window.
  templateName    String?   @map("template_name")
  /// "HH:mm" quiet-hours window in Asia/Amman. When "away" match mode is on
  /// the rule fires only inside this window; otherwise it just suppresses.
  quietHoursStart String?   @map("quiet_hours_start")
  quietHoursEnd   String?   @map("quiet_hours_end")
  /// Lower = earlier in evaluation. Default 100.
  priority        Int       @default(100)
  /// Cooldown between auto-replies to the same contact (minutes). Stops
  /// loops / harassment; 0 disables.
  cooldownMinutes Int       @default(60) @map("cooldown_minutes")
  /// Optional tag added to the contact on match, for segmentation.
  addTag          String?   @map("add_tag")
  isActive        Boolean   @default(true) @map("is_active")
  timesFired      Int       @default(0) @map("times_fired")
  lastFiredAt     DateTime? @map("last_fired_at")
  createdByUserId Int?      @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([isActive, priority])
  @@map("whatsapp_auto_reply_rules")
}

/// Cached snapshot of the message templates registered on the WABA. The
/// source of truth is Meta — we refresh via `GET /v{ver}/{WABA_ID}/message_templates`.
/// Only APPROVED templates are usable for outbound sends outside the 24h window.
model WhatsAppTemplate {
  id              Int      @id @default(autoincrement())
  /// Meta's template name (slug — lowercase snake_case).
  name            String
  language        String   @default("ar")
  category        String   @default("UTILITY") // AUTHENTICATION | MARKETING | UTILITY
  /// APPROVED | PENDING | REJECTED | PAUSED | DISABLED
  status          String   @default("PENDING")
  components      Json?
  metaId          String?  @unique @map("meta_id")
  rejectionReason String?  @map("rejection_reason")
  lastSyncedAt    DateTime @default(now()) @map("last_synced_at")

  @@unique([name, language])
  @@index([status])
  @@map("whatsapp_templates")
}

/// CRM-grade phonebook entry — one row per E.164 phone number that we track
/// (regardless of whether it ever messaged us on WhatsApp). Serves the
/// `/whatsapp/phonebook` page and powers contact lookup in the inbox.
model WhatsAppContact {
  id              Int       @id @default(autoincrement())
  /// E.164 digits, no leading "+". Matches WhatsAppMessage.contactPhone.
  phone           String    @unique
  /// Preferred display name (falls back to nickname / phone).
  displayName     String?   @map("display_name")
  /// Profile name as advertised by the contact on WhatsApp itself
  /// (`contacts[].profile.name` on every inbound webhook). Refreshed on each
  /// message so it stays in sync with what the customer changes on their side.
  /// Never overwrites the user-edited `displayName`.
  waProfileName   String?   @map("wa_profile_name")
  nickname        String?
  email           String?
  company         String?
  notes           String?
  /// Free-form tag list, e.g. ["VIP", "corporate", "booking.com"].
  tags            String[]  @default([])
  /// Arbitrary KV for org-specific fields (e.g. preferred language, rewards #).
  customFields    Json?     @map("custom_fields")
  /// How this contact first entered the phonebook:
  /// "whatsapp" | "manual" | "reservation" | "guest_account" | "import"
  source          String    @default("whatsapp")
  /// Has the customer opted-in to marketing? Only opted-in contacts may be
  /// targeted by outbound bulk template sends per Meta policy.
  optedIn         Boolean   @default(false) @map("opted_in")
  /// When true, inbound messages are ignored by staff tooling (UI hides them).
  isBlocked       Boolean   @default(false) @map("is_blocked")
  /// Last time we saw activity from this contact (inbound OR profile update).
  lastSeenAt      DateTime? @map("last_seen_at")
  /// Last time any message (inbound or outbound) was exchanged.
  lastMessageAt   DateTime? @map("last_message_at")
  createdByUserId Int?      @map("created_by_user_id")
  updatedByUserId Int?      @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  createdBy    User?                 @relation("WhatsAppContactCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy    User?                 @relation("WhatsAppContactUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  conversation WhatsAppConversation?

  @@index([source])
  @@index([isBlocked])
  @@index([lastMessageAt])
  @@map("whatsapp_contacts")
}

/// Conversation thread metadata — one row per distinct contact phone. Holds
/// assignment, status, priority, and counters. Message rows link back via
/// `WhatsAppMessage.conversationId`.
model WhatsAppConversation {
  id                   Int       @id @default(autoincrement())
  /// The contact phone (E.164 digits). `contact_phone` on messages FK's back
  /// here logically — enforced by the upsert helper, not Prisma.
  contactPhone         String    @unique @map("contact_phone")
  /// Formal FK to the phonebook row for this number. Always populated by the
  /// upsert helper; nullable only to keep migrations forgiving.
  contactId            Int?      @unique @map("contact_id")
  /// Currently assigned staff member — null = unassigned.
  assignedToUserId     Int?      @map("assigned_to_user_id")
  assignedAt           DateTime? @map("assigned_at")
  assignedByUserId     Int?      @map("assigned_by_user_id")
  /// "open" | "pending" | "resolved" | "archived"
  status               String    @default("open")
  /// "low" | "normal" | "high" | "urgent"
  priority             String    @default("normal")
  lastMessageAt        DateTime? @map("last_message_at")
  /// First time the customer messaged us in this thread. Used for SLA metrics.
  firstInboundAt       DateTime? @map("first_inbound_at")
  /// Timestamp of the first staff reply after the first inbound. Frozen once set.
  firstResponseAt      DateTime? @map("first_response_at")
  /// Denormalised unread counter (inbound messages not yet read by anyone).
  unreadCount          Int       @default(0) @map("unread_count")
  /// When the current assignee last opened this thread (for their personal badge).
  lastReadByAssigneeAt DateTime? @map("last_read_by_assignee_at")
  /// When true, suppresses sounds/push for this thread only.
  isMuted              Boolean   @default(false) @map("is_muted")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  contact      WhatsAppContact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo   User?                       @relation("WhatsAppConversationAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  assignedBy   User?                       @relation("WhatsAppConversationAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  messages     WhatsAppMessage[]
  notes        WhatsAppConversationNote[]
  events       WhatsAppConversationEvent[]
  botConv      BotConversation?
  shadowDrafts BotShadowDraft[]

  @@index([assignedToUserId, status, lastMessageAt])
  @@index([status, lastMessageAt])
  @@index([priority])
  @@map("whatsapp_conversations")
}

/// Internal ("private") note attached to a conversation — visible to staff
/// only, never sent to the customer. Shown inline in the thread as a yellow
/// sticky separator.
model WhatsAppConversationNote {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  authorUserId   Int      @map("author_user_id")
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User                 @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("whatsapp_conversation_notes")
}

/// Audit trail for every mutating action on a conversation. Powers the
/// right-hand "history" timeline and gives us a clean compliance trail.
model WhatsAppConversationEvent {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  /// "assigned" | "unassigned" | "claimed" | "transferred" | "status_changed"
  /// | "priority_changed" | "tag_added" | "tag_removed" | "muted" | "unmuted"
  /// | "blocked" | "unblocked" | "note_added"
  action         String
  /// Who performed the action (null for system events like "auto_reopened").
  actorUserId    Int?     @map("actor_user_id")
  /// Optional arbitrary detail, e.g. { fromUserId: 1, toUserId: 2 }.
  meta           Json?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actor        User?                @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("whatsapp_conversation_events")
}

/// A single Web Push subscription (per-user, per-device/browser). Used by
/// `src/lib/whatsapp/push-server.ts` to deliver OS notifications when the
/// inbox tab is backgrounded or closed.
model WhatsAppPushSubscription {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  /// The PushSubscription endpoint URL — unique per browser/device.
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?  @map("user_agent")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("whatsapp_push_subscriptions")
}

/// Per-user WhatsApp notification preferences — one row per user.
model WhatsAppNotificationPref {
  userId          Int      @id @map("user_id")
  pushEnabled     Boolean  @default(true) @map("push_enabled")
  soundEnabled    Boolean  @default(true) @map("sound_enabled")
  /// Key into the bundled sound set (`public/sounds/*.mp3`).
  soundKey        String   @default("whatsapp-notify") @map("sound_key")
  /// "mine"  = only notify when the conversation is assigned to me.
  /// "all"   = notify for every inbound (subject to permissions).
  /// "mentions" = future — only when @-mentioned in internal notes.
  notifyScope     String   @default("all") @map("notify_scope")
  /// Optional quiet-hours window stored as "HH:mm" strings in the user's
  /// local timezone (best-effort — we don't track per-user TZ yet).
  quietHoursStart String?  @map("quiet_hours_start")
  quietHoursEnd   String?  @map("quiet_hours_end")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("whatsapp_notification_prefs")
}

// ============================================================================
// AI Concierge Bot ("WhatsApp Booking Bot") — Phase 0+
//
// Sits beside the existing WhatsAppConversation/Message/Auto-Reply tables and
// powers the hybrid tool-calling agent that books a stay end-to-end. All
// runtime state needed to resume a conversation across hours/days lives here;
// the WhatsApp-protocol-level rows stay in `whatsapp_*` and remain the source
// of truth for the inbox UI even when the bot is off.
// ============================================================================

/// One persistent bot session per contact phone. Holds the dialog state,
/// collected slots (dates/guests/category), the current pending hold, the
/// active Stripe payment link, and rolling LLM cost accounting. There is at
/// most one row per phone (`@unique`); transitions are mutated in-place.
model BotConversation {
  id               Int       @id @default(autoincrement())
  /// E.164 digits — same shape used everywhere else in the WhatsApp module.
  contactPhone     String    @unique @map("contact_phone")
  /// Soft-link to the staff-facing conversation row (assignment/notes/events).
  conversationId   Int?      @unique @map("conversation_id")
  /// The GuestAccount we auto-provisioned on first contact. Null until the
  /// bot has confirmed the guest's display name and created the account.
  guestAccountId   Int?      @map("guest_account_id")
  /// Finite-state machine label. Free text on purpose so we can extend it
  /// without migrations: idle | greeting | collecting | quoting | holding |
  /// awaiting_payment | confirmed | escalated | done | opted_out.
  state            String    @default("idle")
  /// Bag of slot values the dialog has collected so far. Free-shape JSON:
  /// `{ checkIn?, checkOut?, guests?, preferredCategory?, guestName?,
  ///    language?, lastShownOptions? }`.
  slots            Json      @default("{}")
  /// Pointer to the current `Reservation` with status = "pending_hold".
  lastHoldId       Int?      @map("last_hold_id")
  /// Snapshot of the last quote shown to the guest, used by the runtime
  /// price validator (the LLM is not allowed to invent prices).
  lastQuoteJson    Json?     @map("last_quote_json")
  /// Stripe Checkout Session id for the active payment link (if any).
  paymentSessionId String?   @map("payment_session_id")
  paymentLinkUrl   String?   @map("payment_link_url")
  paymentExpiresAt DateTime? @map("payment_expires_at")
  /// Rolling counters — fed every time `engine.runBotTurn` calls the LLM.
  llmTurns         Int       @default(0) @map("llm_turns")
  llmTokensIn      Int       @default(0) @map("llm_tokens_in")
  llmTokensOut     Int       @default(0) @map("llm_tokens_out")
  /// USD cost across all turns of this conversation.
  costUsd          Decimal   @default(0) @map("cost_usd") @db.Decimal(10, 4)
  /// Set when the bot voluntarily handed off to a human; never cleared.
  escalatedAt      DateTime? @map("escalated_at")
  escalationReason String?   @map("escalation_reason")
  lastInboundAt    DateTime? @map("last_inbound_at")
  lastOutboundAt   DateTime? @map("last_outbound_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  conversation WhatsAppConversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  guestAccount GuestAccount?          @relation(fields: [guestAccountId], references: [id], onDelete: SetNull)
  events       BotConversationEvent[]

  @@index([state, lastInboundAt])
  @@index([guestAccountId])
  @@map("bot_conversations")
}

/// Append-only event log for one bot conversation. Powers debugging,
/// analytics, and (in shadow mode) the per-message decision UI.
model BotConversationEvent {
  id        Int      @id @default(autoincrement())
  botConvId Int      @map("bot_conv_id")
  /// "user_msg" | "bot_msg" | "tool_call" | "tool_result" | "state_change"
  /// | "escalation" | "error" | "shadow_draft" | "circuit_breaker"
  kind      String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  botConv BotConversation @relation(fields: [botConvId], references: [id], onDelete: Cascade)

  @@index([botConvId, createdAt])
  @@index([kind, createdAt])
  @@map("bot_conversation_events")
}

/// Phone numbers the bot is allowed to engage when `WhatsAppConfig.botMode
/// = "allowlist"`. Anything not in here falls through to the existing inbox
/// + auto-reply path. Used during Layer 4 of the staged rollout.
model BotAllowlist {
  id            Int      @id @default(autoincrement())
  /// E.164 digits. Unique to make seeding idempotent.
  phone         String   @unique
  /// Free-text staff note (e.g. "موظف الاستقبال للاختبار").
  note          String?
  addedByUserId Int      @map("added_by_user_id")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  addedBy User @relation("BotAllowlistAdder", fields: [addedByUserId], references: [id], onDelete: Cascade)

  @@map("bot_allowlist")
}

/// Per-inbound-message draft produced by the bot while in "shadow" mode.
/// Staff see one row per inbound under each thread in the inbox and choose
/// to send-as-is, edit, or ignore. Every decision is training feedback.
model BotShadowDraft {
  id               Int       @id @default(autoincrement())
  conversationId   Int       @map("conversation_id")
  /// Soft-link to the inbound `WhatsAppMessage` this draft is responding to.
  /// Unique → at most one draft per inbound message.
  inboundMessageId Int       @unique @map("inbound_message_id")
  /// What the bot would have sent (post-pacing, pre-split). Null when the
  /// bot decided silence was the right answer (rare but possible).
  draftText        String?   @map("draft_text") @db.Text
  /// Tool calls the bot would have executed. They are NOT executed in shadow
  /// mode — booking holds, payment links, and refunds remain dry.
  draftToolCalls   Json?     @map("draft_tool_calls")
  /// USD cost of the LLM turn that produced this draft.
  draftCostUsd     Decimal   @default(0) @map("draft_cost_usd") @db.Decimal(8, 4)
  /// "pending" | "sent" | "edited" | "ignored" | "expired"
  status           String    @default("pending")
  /// What the staff member actually sent (after their edits, if any).
  finalSentText    String?   @map("final_sent_text") @db.Text
  decidedByUserId  Int?      @map("decided_by_user_id")
  decidedAt        DateTime? @map("decided_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  inboundMessage WhatsAppMessage      @relation(fields: [inboundMessageId], references: [id], onDelete: Cascade)
  decidedBy      User?                @relation("BotShadowDraftDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([status, createdAt])
  @@map("bot_shadow_drafts")
}
