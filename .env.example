# ============================================================
#  Hotel-App — قالب متغيرات البيئة (Environment Template)
# ============================================================
#  طريقة الاستخدام:
#    • للتطوير المحلي:   npm run setup:env  (يولّد .env.local تلقائياً)
#      أو يدوياً:         cp .env.example .env.local
#    • للإنتاج (السيرفر): نسخة هذا الملف إلى /opt/hotel-app/.env
#
#  ⚠️ لا ترفع .env أو .env.local إلى Git أبداً.
#  ⚠️ غيّر كل القيم المُعلَّمة بـ CHANGE_ME قبل التشغيل.
# ============================================================


# ── بيئة التشغيل ─────────────────────────────────────────────
# development = تطوير محلي | production = إنتاج
NODE_ENV=development


# ── قاعدة البيانات (PostgreSQL — Prisma) ────────────────────
# للتطوير المحلي (Postgres على جهازك):
#   postgresql://<user>:<pass>@127.0.0.1:5432/<db>?schema=public
# للإنتاج (على السيرفر):
#   postgresql://fakher_user:CHANGE_ME@127.0.0.1:5432/fakher_hotel?schema=public
DATABASE_URL="postgresql://fakher_user:CHANGE_ME@127.0.0.1:5432/fakher_hotel_dev?schema=public"


# ── NextAuth (المصادقة) ──────────────────────────────────────
# سر توقيع الجلسات — يجب أن يكون طويلًا وعشوائياً.
# توليد سريع:   openssl rand -base64 48
# (سكريبت setup:env يولّده تلقائياً)
NEXTAUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# URL الظاهر للمستخدم (بدون / في النهاية)
#   محلي:  http://localhost:3000
#   إنتاج (لوحة الإدارة):  https://admin.mafhotel.com
NEXTAUTH_URL=http://localhost:3000


# ── Public (متاح في المتصفح) ─────────────────────────────────
# يُستخدم في meta tags و canonical URLs (النطاق العام للضيوف).
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ── فصل النطاقات (إدارة ↔ عام) ──────────────────────────────
# في الإنتاج يعمل التطبيق على نطاقين يُقدَّمان بنفس عملية Next.js:
#   • admin.mafhotel.com  → لوحة الإدارة (الموظفين)
#   • mafhotel.com        → الموقع العام للضيوف (الهبوط + الحجز + /account)
#
# اضبط القيم التالية في الإنتاج فقط؛ اتركها فارغة محلياً ليعمل
# localhost:3000 بنمط مضيف واحد كما كان سابقاً.
#
# ADMIN_HOST            = النطاق الذي يخدم واجهة الإدارة (بدون سكيم/بورت).
# PUBLIC_HOST           = النطاق العام للضيوف (بدون سكيم/بورت).
# PUBLIC_HOST_ALIASES   = أسماء إضافية تُعامَل كالنطاق العام (فواصل)، مثلاً www أو نطاق مخصص.
#                         www.<PUBLIC_HOST> مُضاف ضمنياً ولا داعي لإدراجه.
# SESSION_COOKIE_DOMAIN = نطاق كوكي الجلسة لمشاركة الدخول بين النطاقين.
#                         اضبطها على `.mafhotel.com` مع النقطة الأولى.
#
# ADMIN_HOST=admin.mafhotel.com
# PUBLIC_HOST=mafhotel.com
# PUBLIC_HOST_ALIASES=
# SESSION_COOKIE_DOMAIN=.mafhotel.com


# ── تشفير بيانات Booking (اختياري) ──────────────────────────
# مفتاح تشفير بيانات Booking credentials (AES-256).
# إذا تُرك فارغاً سيُشتقّ من NEXTAUTH_SECRET (للتطوير فقط).
# للإنتاج ولّده عبر:   openssl rand -base64 32
BOOKING_ENC_KEY=


# ── خدمة Realtime (Socket.IO) ────────────────────────────────
# تعمل في process منفصل (مجلد realtime/) على منفذ 3001 افتراضياً.
REALTIME_PORT=3001
REALTIME_HOST=127.0.0.1
# REALTIME_ENV_FILE=/opt/hotel-app/.env   # تجاوز مسار تحميل .env (اختياري)
# REALTIME_DEBUG_AUTH=0                   # 1 لتفعيل سجلات مصادقة Socket.IO


# ── مسارات الرفع ─────────────────────────────────────────────
# إذا تُركت فارغة:
#   • development → <project>/uploads
#   • production  → /opt/hotel-app/uploads
# UPLOADS_DIR=


# ── Booking Bot (اختياري — مجلد bot/) ───────────────────────
# BOOKING_POLL_INTERVAL_MS=15000
# BOOKING_HEADLESS=true
# BOOKING_SLOWMO_MS=0
# BOOKING_SCREENSHOT_DIR=./bot/screenshots


# ── Google Cloud Vision (اختياري) ────────────────────────────
# لا يُضبط عبر متغير؛ ضع ملف google-vision-key.json في جذر المشروع.
# (المسار: ./google-vision-key.json — مُدرج في .gitignore)


# ── تسجيل الدخول الاجتماعي (اختياري) ─────────────────────────
# عند ضبط هذه القيم تظهر أزرار "متابعة باستخدام Google/Apple" في
# شاشات تسجيل دخول الضيف وصفحة الحجز. اتركها فارغة لإخفاء الأزرار.
#
# Google: أنشئ OAuth 2.0 Client من https://console.cloud.google.com
#   • Authorized redirect URI:
#       http://localhost:3000/api/auth/callback/google           (تطوير)
#       https://mafhotel.com/api/auth/callback/google            (إنتاج)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# Apple: يحتاج Apple Developer Account ($99/سنة) + Service ID + Key
#   • Service ID:      من Certificates → Identifiers → Services IDs
#   • Return URL:      https://mafhotel.com/api/auth/callback/apple
#   • APPLE_CLIENT_SECRET هو JWT موقّع (انظر `next-auth` apple provider docs)
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
#
# الإشارات التالية تتحكّم بإظهار الأزرار في الواجهة فقط — يجب ضبطها على
# "1" *بعد* أن تُفعّل المفاتيح أعلاه فعلياً، وإلا سيظهر زر فارغ يفشل عند الضغط.
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=1
# NEXT_PUBLIC_APPLE_AUTH_ENABLED=1


# ── WhatsApp OTP / Click-to-Login (اختياري) ─────────────────
# اسم قالب OTP المعتمد في Meta Business Manager (نوع AUTHENTICATION).
# إذا تُرك فارغاً نُرسل رسالة نصية مدمجة (الرمز + رابط Click-to-Login)
# داخل نافذة المحادثة المفتوحة فقط — لذا يُنصح به في الإنتاج.
# WHATSAPP_OTP_TEMPLATE=otp_login_ar


# ── GitHub (اختياري — للزر "نشر إلى الإنتاج") ──────────────
# يُستخدم من صفحة /settings/whatsapp لدفع الأسرار إلى GitHub
# Secrets ثم تشغيل workflow النشر تلقائياً دون الحاجة إلى terminal.
#
# GITHUB_PAT: Fine-grained PAT على المستودع التالي فقط، بالصلاحيات:
#   • Secrets: Read/Write
#   • Actions: Read/Write  (لتشغيل workflow_dispatch)
#   • Contents: Read
# أنشئ واحداً هنا: https://github.com/settings/personal-access-tokens/new
# GITHUB_PAT=github_pat_xxx
# GITHUB_REPO=EngOsamaQazan/HotelMangment
