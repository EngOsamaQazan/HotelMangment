# ============================================================
#  Hotel-App — قالب متغيرات البيئة (Environment Template)
# ============================================================
#  طريقة الاستخدام:
#    • للتطوير المحلي:   npm run setup:env  (يولّد .env.local تلقائياً)
#      أو يدوياً:         cp .env.example .env.local
#    • للإنتاج (السيرفر): نسخة هذا الملف إلى /opt/hotel-app/.env
#
#  ⚠️ لا ترفع .env أو .env.local إلى Git أبداً.
#  ⚠️ غيّر كل القيم المُعلَّمة بـ CHANGE_ME قبل التشغيل.
# ============================================================


# ── بيئة التشغيل ─────────────────────────────────────────────
# development = تطوير محلي | production = إنتاج
NODE_ENV=development


# ── قاعدة البيانات (PostgreSQL — Prisma) ────────────────────
# للتطوير المحلي (Postgres على جهازك):
#   postgresql://<user>:<pass>@127.0.0.1:5432/<db>?schema=public
# للإنتاج (على السيرفر):
#   postgresql://fakher_user:CHANGE_ME@127.0.0.1:5432/fakher_hotel?schema=public
DATABASE_URL="postgresql://fakher_user:CHANGE_ME@127.0.0.1:5432/fakher_hotel_dev?schema=public"


# ── NextAuth (المصادقة) ──────────────────────────────────────
# سر توقيع الجلسات — يجب أن يكون طويلًا وعشوائياً.
# توليد سريع:   openssl rand -base64 48
# (سكريبت setup:env يولّده تلقائياً)
NEXTAUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# URL الظاهر للمستخدم (بدون / في النهاية)
#   محلي:  http://localhost:3000
#   إنتاج: https://hotel.aqssat.co
NEXTAUTH_URL=http://localhost:3000


# ── Public (متاح في المتصفح) ─────────────────────────────────
# يُستخدم في meta tags و canonical URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ── تشفير بيانات Booking (اختياري) ──────────────────────────
# مفتاح تشفير بيانات Booking credentials (AES-256).
# إذا تُرك فارغاً سيُشتقّ من NEXTAUTH_SECRET (للتطوير فقط).
# للإنتاج ولّده عبر:   openssl rand -base64 32
BOOKING_ENC_KEY=


# ── خدمة Realtime (Socket.IO) ────────────────────────────────
# تعمل في process منفصل (مجلد realtime/) على منفذ 3001 افتراضياً.
REALTIME_PORT=3001
REALTIME_HOST=127.0.0.1
# REALTIME_ENV_FILE=/opt/hotel-app/.env   # تجاوز مسار تحميل .env (اختياري)
# REALTIME_DEBUG_AUTH=0                   # 1 لتفعيل سجلات مصادقة Socket.IO


# ── مسارات الرفع ─────────────────────────────────────────────
# إذا تُركت فارغة:
#   • development → <project>/uploads
#   • production  → /opt/hotel-app/uploads
# UPLOADS_DIR=


# ── Booking Bot (اختياري — مجلد bot/) ───────────────────────
# BOOKING_POLL_INTERVAL_MS=15000
# BOOKING_HEADLESS=true
# BOOKING_SLOWMO_MS=0
# BOOKING_SCREENSHOT_DIR=./bot/screenshots


# ── Google Cloud Vision (اختياري) ────────────────────────────
# لا يُضبط عبر متغير؛ ضع ملف google-vision-key.json في جذر المشروع.
# (المسار: ./google-vision-key.json — مُدرج في .gitignore)


# ── GitHub (اختياري — للزر "نشر إلى الإنتاج") ──────────────
# يُستخدم من صفحة /settings/whatsapp لدفع الأسرار إلى GitHub
# Secrets ثم تشغيل workflow النشر تلقائياً دون الحاجة إلى terminal.
#
# GITHUB_PAT: Fine-grained PAT على المستودع التالي فقط، بالصلاحيات:
#   • Secrets: Read/Write
#   • Actions: Read/Write  (لتشغيل workflow_dispatch)
#   • Contents: Read
# أنشئ واحداً هنا: https://github.com/settings/personal-access-tokens/new
# GITHUB_PAT=github_pat_xxx
# GITHUB_REPO=EngOsamaQazan/HotelMangment
