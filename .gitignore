# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — كل ملفات البيئة محظورة ما عدا القوالب الموثّقة
.env
.env.*
!.env.example
!.env.*.example

# Google Cloud credentials
google-vision-key.json
*-key.json

# database
*.db
*.db-journal

# Tesseract trained data
*.traineddata

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

tmp-import/
excel-import-preview.json

# Ad-hoc debugging artefacts (server inspection scripts, Webmin helpers,
# screenshots captured by MCP browser tooling, saved HTML snippets).
# They are kept out of source control to avoid polluting the repository.
_*.sh
_*.ps1
*.png
*.jpg
*.jpeg
# …except brand assets in public/ and src/app/ which are part of the app bundle.
!public/*.png
!public/*.jpg
!public/*.jpeg
!public/rooms/*.jpg
!src/app/**/*.png
/init.html
/login_resp.html
/out.html
/shell.html
/.playwright-mcp/

import-guests-preview.json

# PM2
.pm2-logs/

# DB backups / one-off dumps
backups/
backup/
*.sql
*.dump
!prisma/**/*.sql

# User-uploaded files (avatars, chat/task attachments, etc.)
/uploads/

# Scratch / temporary agent artifacts (commit messages, nginx drafts, etc.)
.tmp/

# One-off maintenance scripts (rollbacks, data fixes) — kept locally only.
# Whitelist scripts/ by default; add specific one-shots here as needed.
scripts/fix-voided-entries-status.cjs
scripts/rollback-reservations-after-adjustment.cjs

# Local dev artifacts — session cookies captured for API probing, and
# cloudflared tunnel logs used while testing WhatsApp webhooks.
cookies.txt
tunnel.log
cloudflared*.log
