{
  "name": "hotel-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "setup:env": "node scripts/setup-env.cjs",
    "env:check": "node scripts/check-env.cjs",
    "db:sync-from-prod": "node scripts/sync-from-prod.cjs",
    "db:push": "prisma db push",
    "db:seed": "npx ts-node --compiler-options {\"module\":\"commonjs\"} prisma/seed.ts",
    "db:seed-permissions": "npx ts-node --project tsconfig.scripts.json prisma/seed-permissions.ts",
    "db:seed-demo-tasks": "npx ts-node --project tsconfig.scripts.json scripts/seed-demo-tasks.ts",
    "db:seed-unit-types": "npx ts-node --project tsconfig.scripts.json prisma/seed-unit-types.ts",
    "db:backfill-units": "npx ts-node --project tsconfig.scripts.json prisma/scripts/backfill-unit-types.ts",
    "db:migrate-prices": "npx ts-node --project tsconfig.scripts.json prisma/scripts/migrate-prices.ts",
    "db:migrate-user-roles": "npx ts-node --project tsconfig.scripts.json scripts/migrate-user-roles.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "check:permissions": "npx ts-node --project tsconfig.scripts.json scripts/check-permissions.ts",
    "prebuild": "npm run check:permissions",
    "import:guests": "node scripts/import-guests-from-images.cjs",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"commonjs\"} prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/vision": "^5.3.5",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-virtual": "^3.13.24",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
